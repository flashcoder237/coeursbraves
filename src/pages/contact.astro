---
import Layout from "~/components/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import Icon from "~/components/Icon.astro";
import { site } from "~/data/site";
---

<Layout title="Contact" description="Contactez Cœurs Braves — association internationale africaine présente au Cameroun, en RCA, en Allemagne et dans la diaspora.">
  <PageHero
    image="/images/cb/children-flag.jpg"
    kicker="Contact"
    title="Échangeons ensemble"
    subtitle="Une question, un projet, une envie de vous engager ? Notre équipe vous répond."
    height="min-h-[40vh]"
  />

  <section class="bg-white">
    <div class="container-cb py-16 md:py-20 grid md:grid-cols-12 gap-10">
      <!-- Infos -->
      <div class="md:col-span-5 reveal">
        <p class="section-title left">Nos <strong>coordonnées</strong></p>
        <div class="mt-6 space-y-4">
          <div class="flex gap-4 bg-paper-warm border border-hairline rounded-xl p-5">
            <span class="inline-flex w-11 h-11 rounded-lg bg-red/10 text-red items-center justify-center shrink-0"><Icon name="mail" class="w-5 h-5" /></span>
            <div>
              <p class="font-display font-semibold">E-mail</p>
              <a href={`mailto:${site.email}`} class="text-red hover:underline">{site.email}</a>
            </div>
          </div>
          <div class="flex gap-4 bg-paper-warm border border-hairline rounded-xl p-5">
            <span class="inline-flex w-11 h-11 rounded-lg bg-green/10 text-green items-center justify-center shrink-0"><Icon name="facebook" class="w-5 h-5" /></span>
            <div>
              <p class="font-display font-semibold">Facebook</p>
              <a href={site.social.facebook} target="_blank" rel="noopener" class="text-red hover:underline">Les Cœurs Braves</a>
            </div>
          </div>
          <div class="flex gap-4 bg-paper-warm border border-hairline rounded-xl p-5">
            <span class="inline-flex w-11 h-11 rounded-lg bg-gold/15 text-gold-dark items-center justify-center shrink-0"><Icon name="map-pin" class="w-5 h-5" /></span>
            <div>
              <p class="font-display font-semibold">Présence</p>
              <p class="text-ink-mute text-sm">{site.countries.join(" · ")}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Formulaire -->
      <div class="md:col-span-7 reveal">
        <form class="bg-paper-cool border border-hairline rounded-3xl p-8 grid sm:grid-cols-2 gap-4" onsubmit="return false">
          <input required placeholder="Nom et prénom" class="rounded-xl border border-hairline px-4 py-3 outline-none focus:border-red" />
          <input required type="email" placeholder="Adresse e-mail" class="rounded-xl border border-hairline px-4 py-3 outline-none focus:border-red" />
          <input placeholder="Pays de résidence" class="rounded-xl border border-hairline px-4 py-3 outline-none focus:border-red" />
          <select class="rounded-xl border border-hairline px-4 py-3 outline-none focus:border-red text-ink-mute">
            <option>Objet de votre message</option>
            <option>Adhésion / bénévolat</option>
            <option>Partenariat</option>
            <option>Don / mécénat</option>
            <option>Proposer un projet</option>
            <option>Autre</option>
          </select>
          <textarea placeholder="Votre message" rows="5" class="sm:col-span-2 rounded-xl border border-hairline px-4 py-3 outline-none focus:border-red"></textarea>
          <button type="submit" class="btn btn-red sm:col-span-2 justify-center">Envoyer mon message</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
