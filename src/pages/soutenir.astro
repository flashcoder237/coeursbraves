---
import Layout from "~/components/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import Icon from "~/components/Icon.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import MotifTexture from "~/components/MotifTexture.astro";
import PatternBand from "~/components/PatternBand.astro";
import { donation, allocation } from "~/data/org";

const pct = Math.min(100, Math.round((donation.campaign.raised / donation.campaign.goal) * 100));
const fmtEur = (n: number) => new Intl.NumberFormat("fr-FR").format(n);

const impacts = [
  { icon: "graduation-cap", t: "Former", d: "Développer les compétences professionnelles et entrepreneuriales.", chip: "bg-terra/12 text-terra" },
  { icon: "hand-heart", t: "Accompagner", d: "Offrir un mentorat, des conseils et un suivi personnalisé.", chip: "bg-emerald/12 text-emerald" },
  { icon: "bulb", t: "Innover", d: "Créer des solutions technologiques au service des communautés.", chip: "bg-gold/15 text-gold" },
  { icon: "rocket", t: "Entreprendre", d: "Soutenir les porteurs de projets et favoriser la création d'emplois.", chip: "bg-terra/12 text-terra" },
  { icon: "sprout", t: "Nourrir", d: "Développer des initiatives agricoles innovantes.", chip: "bg-emerald/12 text-emerald" },
  { icon: "users", t: "Mobiliser", d: "Créer des actions collectives qui renforcent les communautés.", chip: "bg-gold/15 text-gold" },
];

const modes = [
  { t: "Faire un don ponctuel", d: "Une contribution unique pour soutenir les actions prioritaires de l'association.", c: "terra" },
  { t: "Devenir donateur régulier", d: "Un soutien mensuel pour accompagner durablement le développement de nos programmes.", c: "emerald" },
  { t: "Soutenir un programme", d: "Affectez votre contribution à un domaine qui vous tient à cœur : éducation, agriculture, innovation…", c: "gold" },
  { t: "Devenir mécène", d: "Entreprises, fondations et philanthropes accompagnent des projets structurants à fort impact.", c: "terra" },
  { t: "Faire un don en nature", d: "Matériel informatique, équipements, fournitures, ressources agricoles, espaces ou compétences.", c: "emerald" },
  { t: "Financer un projet", d: "Soutenez directement le lancement d'une initiative créatrice de valeur.", c: "gold" },
];

const gouvernance = [
  "Une gestion responsable des fonds",
  "Un suivi des projets financés",
  "Des indicateurs d'impact mesurables",
  "Des rapports d'activité réguliers",
  "Une amélioration continue de nos pratiques",
];

const border = (c: string) => c === "emerald" ? "border-t-emerald" : c === "gold" ? "border-t-gold" : "border-t-terra";
---

<Layout title="Soutenir notre mission" description="Chaque contribution ouvre une nouvelle opportunité. Soutenez Cœurs Braves : don ponctuel, mensuel, mécénat ou don en nature.">
  <PageHero
    image="/images/cb/agri-produce.jpg"
    kicker="Soutenir notre mission"
    title="Chaque contribution ouvre une nouvelle opportunité"
    subtitle="Investir dans une personne, c'est investir dans l'avenir."
  />

  <!-- Pourquoi + widget don -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24 grid lg:grid-cols-2 gap-12 items-start">
      <div class="reveal">
        <Eyebrow label="Votre soutien" />
        <h2 class="mt-6 section-title left">Pourquoi votre soutien est <strong>essentiel.</strong></h2>
        <p class="mt-5 prose-cb">
          Chez Cœurs Braves, le développement durable commence par l'investissement dans le
          potentiel humain. Nous mobilisons des ressources pour construire des solutions durables.
          <strong>Chaque geste compte.</strong>
        </p>
        <ul class="mt-6 space-y-2.5">
          {["Former des jeunes et développer leurs compétences.","Accompagner les entrepreneurs dans la création de leurs projets.","Soutenir les initiatives agricoles et génératrices de revenus.","Développer des programmes d'innovation et de transformation numérique.","Organiser des actions communautaires pour les plus vulnérables."].map((x) => (
            <li class="flex gap-3 text-ink-soft"><Icon name="check" class="w-5 h-5 text-emerald shrink-0 mt-0.5" /><span>{x}</span></li>
          ))}
        </ul>
      </div>

      <div id="cb-don" class="reveal bg-cream-2 border border-hairline rounded-[1.6rem] p-8 lg:sticky lg:top-24 shadow-sm scroll-mt-28"
        data-onetime={donation.stripe.oneTime} data-monthly={donation.stripe.monthly}
        data-currency={donation.currency} data-impacts={JSON.stringify(donation.impacts)}
        data-default-impact={donation.defaultImpact}>
        <h3 class="font-display font-700 text-xl text-center" style="font-weight:700">Faire un don</h3>

        <!-- Barre de campagne -->
        <div class="mt-5 mb-6">
          <div class="flex items-baseline justify-between text-sm mb-2">
            <span class="font-display font-700 text-terra" style="font-weight:700">{fmtEur(donation.campaign.raised)} {donation.currency}</span>
            <span class="text-ink-mute">objectif {fmtEur(donation.campaign.goal)} {donation.currency}</span>
          </div>
          <div class="progress-track"><span class="progress-fill" style={`--pct:${pct}%`}></span></div>
          <p class="mt-2 text-xs text-ink-mute">{donation.campaign.title} · {donation.campaign.donors} donateurs</p>
        </div>

        <!-- Fréquence -->
        <div class="flex gap-1 bg-cream rounded-full p-1 border border-hairline text-sm">
          <button type="button" data-freq="oneTime" class="cb-freq is-active">Ponctuel</button>
          <button type="button" data-freq="monthly" class="cb-freq">Mensuel</button>
        </div>

        <!-- Montants -->
        <div class="mt-5 grid grid-cols-4 gap-2">
          {donation.presets.map((m, i) => (
            <button type="button" data-amount={m} class:list={["cb-amt", i === 1 && "is-active"]}>{m}&nbsp;{donation.currency}</button>
          ))}
        </div>
        <div class="mt-3 relative">
          <input id="cb-custom" type="number" min="1" inputmode="numeric" placeholder="Autre montant"
            class="w-full rounded-xl border border-hairline px-4 py-3 outline-none focus:border-terra bg-cream" />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-ink-mute">€</span>
        </div>

        <!-- Équivalence d'impact -->
        <p id="cb-impact" class="mt-4 flex items-start gap-2 text-sm text-emerald leading-snug">
          <Icon name="check" class="w-4 h-4 shrink-0 mt-0.5" /><span data-impact-text>Votre don finance une session d'accompagnement entrepreneurial.</span>
        </p>

        <button type="button" id="cb-donate" class="btn btn-terra w-full mt-4">
          Faire un don de <span id="cb-amt-label">50&nbsp;{donation.currency}</span> <Icon name="heart" class="w-4 h-4" />
        </button>
        <p class="mt-4 flex items-center justify-center gap-1.5 text-xs text-ink-mute">
          <Icon name="check" class="w-3.5 h-3.5 text-emerald" /> Paiement 100&nbsp;% sécurisé via Stripe
        </p>
      </div>
    </div>
  </section>

  <!-- Ce que votre contribution rend possible -->
  <section class="bg-cream-2">
    <div class="container-cb py-20 md:py-24">
      <div class="text-center"><Eyebrow label="Votre impact" align="center" /></div>
      <h2 class="mt-6 section-title">Ce que votre contribution rend <strong>possible.</strong></h2>
      <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {impacts.map((im) => (
          <div class="bg-cream border border-hairline rounded-2xl p-7 reveal card-hover">
            <span class:list={["icon-chip w-14 h-14", im.chip]}><Icon name={im.icon} class="w-7 h-7" /></span>
            <h3 class="mt-5 font-display font-700 text-lg" style="font-weight:700">{im.t}</h3>
            <p class="mt-2 text-sm text-ink-mute leading-relaxed">{im.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modes de contribution -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24">
      <div class="text-center"><Eyebrow label="Comment donner" align="center" /></div>
      <h2 class="mt-6 section-title">Les différentes façons de <strong>soutenir.</strong></h2>
      <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {modes.map((m) => (
          <div class:list={["rounded-2xl p-7 border-t-4 bg-cream-2 border border-hairline reveal card-hover", border(m.c)]}>
            <h3 class="font-display font-700 text-lg" style="font-weight:700">{m.t}</h3>
            <p class="mt-2 text-sm text-ink-mute leading-relaxed">{m.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PatternBand height={24} />

  <!-- Transparence (ink) -->
  <section class="relative bg-ink text-white overflow-hidden">
    <MotifTexture class="text-white/[0.05]" />
    <div class="relative container-cb py-20 md:py-24 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <Eyebrow label="Transparence" light />
        <h2 class="mt-6 display-xl !text-white" style="font-size:clamp(1.9rem,4vw,3rem)">
          La confiance au cœur de notre <span class="text-terra-bright">engagement.</span>
        </h2>
        <p class="mt-5 text-white/70 leading-relaxed">
          Nous nous engageons à gérer les ressources qui nous sont confiées avec rigueur,
          responsabilité et transparence.
        </p>
      </div>
      <div class="reveal space-y-5">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
          <p class="font-display font-700 text-white mb-5" style="font-weight:700">Où va votre argent</p>
          {allocation.map((a) => {
            const fill = a.color === "emerald" ? "var(--color-emerald)" : a.color === "gold" ? "var(--color-gold)" : "var(--color-terra-bright)";
            return (
              <div class="mb-4 last:mb-0">
                <div class="flex justify-between text-sm mb-1.5">
                  <span class="text-white/85">{a.label}</span>
                  <span class="font-display font-700 text-white" style="font-weight:700">{a.pct}%</span>
                </div>
                <div class="alloc-track"><span class="alloc-fill" style={`--pct:${a.pct}%;background:${fill}`}></span></div>
              </div>
            );
          })}
          <p class="text-xs text-white/45 mt-4">Répartition indicative — chiffres à confirmer dans le rapport d'activité.</p>
        </div>
        <ul class="grid gap-3">
          {gouvernance.map((g) => (
            <li class="flex items-center gap-3 bg-white/5 border border-white/10 rounded-xl px-5 py-4">
              <span class="icon-chip w-8 h-8 shrink-0 bg-gold/20 text-gold"><Icon name="check" class="w-5 h-5" /></span>
              <span class="text-white/90">{g}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-cream">
    <div class="container-cb py-20 text-center max-w-2xl">
      <p class="font-display text-2xl md:text-3xl leading-snug text-ink" style="font-weight:600;letter-spacing:-0.02em">
        Un investissement dans l'humain produit des bénéfices qui se transmettent de
        <span class="text-terra">génération en génération.</span>
      </p>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <a href="#cb-don" class="btn btn-terra">Faire un don <Icon name="heart" class="w-4 h-4" /></a>
        <a href="/contact/" class="btn btn-outline">Contacter l'équipe</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var root = document.getElementById("cb-don");
      if (!root) return;
      var currency = root.dataset.currency || "€";
      var impacts = {};
      try { impacts = JSON.parse(root.dataset.impacts || "{}"); } catch (e) {}
      var defaultImpact = root.dataset.defaultImpact || "";
      var links = { oneTime: root.dataset.onetime, monthly: root.dataset.monthly };

      var freq = "oneTime";
      var amount = 50;
      var freqBtns = root.querySelectorAll(".cb-freq");
      var amtBtns = root.querySelectorAll(".cb-amt");
      var custom = root.querySelector("#cb-custom");
      var label = root.querySelector("#cb-amt-label");
      var impactText = root.querySelector("[data-impact-text]");
      var donate = root.querySelector("#cb-donate");

      function nf(n) { return new Intl.NumberFormat("fr-FR").format(n); }

      function refresh() {
        if (label) label.innerHTML = nf(amount) + " " + currency + (freq === "monthly" ? "/mois" : "");
        if (impactText) {
          var msg = impacts[amount] || defaultImpact;
          impactText.textContent = freq === "monthly"
            ? "Chaque mois, vous financez " + msg + "."
            : "Votre don finance " + msg + ".";
        }
      }
      function setAmount(v, fromCustom) {
        amount = v;
        amtBtns.forEach(function (b) { b.classList.toggle("is-active", !fromCustom && Number(b.dataset.amount) === v); });
        if (!fromCustom && custom) custom.value = "";
        refresh();
      }

      freqBtns.forEach(function (b) {
        b.addEventListener("click", function () {
          freq = b.dataset.freq;
          freqBtns.forEach(function (x) { x.classList.toggle("is-active", x === b); });
          refresh();
        });
      });
      amtBtns.forEach(function (b) {
        b.addEventListener("click", function () { setAmount(Number(b.dataset.amount), false); });
      });
      if (custom) {
        custom.addEventListener("input", function () {
          var v = parseInt(custom.value, 10);
          if (v > 0) {
            amount = v;
            amtBtns.forEach(function (x) { x.classList.remove("is-active"); });
            refresh();
          }
        });
      }
      function showNote(text) {
        var note = document.getElementById("cb-donate-note");
        if (!note) {
          note = document.createElement("p");
          note.id = "cb-donate-note";
          note.className = "cb-form-note text-center";
          donate.insertAdjacentElement("afterend", note);
        }
        note.textContent = text;
      }
      if (donate) {
        donate.addEventListener("click", function () {
          var url = links[freq];
          if (!url || url.indexOf("COMPL") !== -1) {
            showNote("Le paiement en ligne arrive très bientôt. En attendant, écrivez-nous pour faire un don — merci de votre soutien.");
            return;
          }
          window.open(url, "_blank", "noopener");
        });
      }
      refresh();
    })();
  </script>
</Layout>
