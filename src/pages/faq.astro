---
import Layout from "~/components/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import { faq } from "~/data/site";
---

<Layout title="FAQ" description="Questions fréquentes sur Cœurs Braves : adhésion, formations, partenariats, dons et zones d'intervention.">
  <PageHero
    image="/images/cb/youth-laptop-1.jpg"
    kicker="Questions fréquentes"
    title="Vous avez des questions ?"
    subtitle="Retrouvez l'essentiel sur Cœurs Braves, notre communauté et nos actions."
    height="min-h-[40vh]"
  />

  <section class="bg-white">
    <div class="container-cb py-16 md:py-20 max-w-3xl">
      <div class="space-y-3">
        {faq.map((item, i) => (
          <details class="group bg-paper-warm border border-hairline rounded-xl overflow-hidden reveal" open={i === 0}>
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none px-6 py-5 font-display font-semibold text-ink">
              <span>{item.q}</span>
              <span class="shrink-0 text-red text-2xl leading-none transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-6 pb-6 -mt-1 text-ink-soft leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>

      <div class="mt-12 text-center bg-paper-cool border border-hairline rounded-2xl p-8">
        <h2 class="font-display font-bold text-xl">Vous n'avez pas trouvé votre réponse ?</h2>
        <p class="mt-2 text-ink-mute">Notre équipe est là pour vous accompagner.</p>
        <a href="/contact/" class="btn btn-red mt-5">Nous contacter</a>
      </div>
    </div>
  </section>
</Layout>
