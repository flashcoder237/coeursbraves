---
import Layout from "~/components/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import Icon from "~/components/Icon.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import Motif from "~/components/Motif.astro";
import MotifTexture from "~/components/MotifTexture.astro";
import PatternBand from "~/components/PatternBand.astro";
import { poles } from "~/data/site";
import { getLangFromUrl, localizePath } from "~/i18n/ui";
import { getEco } from "~/i18n/ecosysteme";
import { getHome } from "~/i18n/home";
import { getMethode, getEngagements } from "~/i18n/values";

const lang = getLangFromUrl(Astro.url);
const L = (p: string) => localizePath(p, lang);
const eco = getEco(lang);
const poleTxt = getHome(lang).poles;
const methode = getMethode(lang);
const engagements = getEngagements(lang);

const chip = (c: string) =>
  c === "green" ? "bg-emerald text-white" : c === "gold" ? "bg-gold text-ink" : "bg-terra text-white";
---

<Layout title={eco.hero.kicker} description={eco.hero.subtitle}>
  <PageHero
    image="/images/cb/grid-activities-1.png"
    kicker={eco.hero.kicker}
    title={eco.hero.title}
    subtitle={eco.hero.subtitle}
  />

  <!-- Pôles -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24">
      <div class="max-w-2xl">
        <Eyebrow label={eco.poles.eyebrow} />
        <h2 class="mt-6 section-title left">{eco.poles.title} <strong>{eco.poles.strong}</strong></h2>
      </div>
      <div class="mt-16 space-y-16 md:space-y-24">
        {poles.map((p, i) => {
          const txt = poleTxt[p.slug] ?? { baseline: p.baseline, text: p.text };
          return (
          <div class:list={["grid md:grid-cols-2 gap-8 md:gap-14 items-center reveal", i % 2 === 1 && "md:[&>*:first-child]:order-2"]}>
            <div class="relative rounded-[2rem] overflow-hidden shadow-xl">
              <img src={p.image} alt={p.name} class="w-full aspect-[4/3] object-cover" loading="lazy" />
              <span class:list={["absolute top-5 left-5 icon-chip w-14 h-14 shadow-lg", chip(p.color)]}><Icon name={p.icon} class="w-7 h-7" /></span>
              {p.logo && (
                <span class="absolute bottom-5 right-5 bg-cream rounded-2xl p-2.5 shadow-lg">
                  <img src={p.logo} alt={`Logo ${p.name}`} class="w-12 h-12 object-contain" loading="lazy" />
                </span>
              )}
              <div class="absolute bottom-0 left-0 right-0"><PatternBand height={16} /></div>
            </div>
            <div>
              <span class="font-display font-700 text-sm text-terra" style="font-weight:700">{eco.poles.label} {String(i + 1).padStart(2, "0")}</span>
              <h3 class="mt-2 display-xl !text-ink" style="font-size:clamp(1.7rem,3.2vw,2.4rem)">{p.name}</h3>
              <p class="mt-3 text-lg font-display font-600 text-terra" style="font-weight:600">{txt.baseline}</p>
              <p class="mt-4 prose-cb">{txt.text}</p>
            </div>
          </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Méthode d'impact (forêt) -->
  <section class="relative bg-forest text-white overflow-hidden">
    <MotifTexture class="text-white/[0.05]" />
    <Motif name="chevron" class="absolute -left-10 -bottom-10 w-72 h-72 text-white/[0.05] hidden md:block" />
    <div class="relative container-cb py-20 md:py-24">
      <div class="max-w-2xl">
        <Eyebrow label={eco.methode.eyebrow} light />
        <h2 class="mt-6 display-xl !text-white" style="font-size:clamp(2rem,4vw,3.2rem)">
          {eco.methode.title} <span class="text-terra-bright">{eco.methode.accent}</span>
        </h2>
        <p class="mt-5 text-white/60 text-lg">{eco.methode.subtitle}</p>
      </div>
      <div class="mt-14 grid grid-cols-2 md:grid-cols-4 gap-4">
        {methode.map((m, i) => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 reveal">
            <span class="font-display font-700 text-3xl text-terra-bright" style="font-weight:700">{String(i + 1).padStart(2, "0")}</span>
            <p class="mt-2 font-display font-600 text-lg text-white" style="font-weight:600">{m}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PatternBand height={24} />

  <!-- Engagements -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24 grid lg:grid-cols-12 gap-10 lg:gap-16">
      <div class="lg:col-span-5 reveal">
        <Eyebrow label={eco.engagements.eyebrow} />
        <h2 class="mt-6 section-title left">{eco.engagements.title} <strong>{eco.engagements.strong}</strong></h2>
        <p class="mt-5 prose-cb">{eco.engagements.lead}</p>
        <a href={L("/partenaires/")} class="btn btn-terra mt-6">{eco.engagements.cta} <Icon name="arrow-right" class="w-4 h-4" /></a>
      </div>
      <ul class="lg:col-span-7 grid sm:grid-cols-2 gap-3 reveal">
        {engagements.map((e) => (
          <li class="flex gap-3 bg-cream border border-hairline rounded-xl p-5">
            <span class="icon-chip w-8 h-8 shrink-0 bg-terra/12 text-terra"><Icon name="check" class="w-5 h-5" /></span>
            <span class="text-ink-soft">{e}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
