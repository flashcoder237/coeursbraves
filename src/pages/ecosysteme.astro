---
import Layout from "~/components/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import Icon from "~/components/Icon.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import PatternBand from "~/components/PatternBand.astro";
import { poles, methode, engagements } from "~/data/site";
---

<Layout title="Notre écosystème" description="Découvrez les six pôles complémentaires de Cœurs Braves : Academy, Fermiers, ASSAA Technologies, Technology Center, Immigration Services et La Marmite.">
  <PageHero
    image="/images/cb/grid-activities-1.png"
    kicker="Notre écosystème"
    title="Un écosystème au service du développement"
    subtitle="Bien plus qu'une association : plusieurs pôles complémentaires qui collaborent pour accompagner les personnes et soutenir les projets."
  />

  <!-- Pôles -->
  <section class="bg-white">
    <div class="container-cb py-16 md:py-20 space-y-16">
      {poles.map((p, i) => (
        <div class:list={["grid md:grid-cols-2 gap-8 md:gap-12 items-center reveal", i % 2 === 1 && "md:[&>*:first-child]:order-2"]}>
          <div class="relative rounded-2xl overflow-hidden">
            <img src={p.image} alt={p.name} class="w-full aspect-[4/3] object-cover" loading="lazy" />
            <span class:list={["absolute top-4 left-4 w-14 h-14 rounded-xl grid place-items-center text-white shadow-lg", p.color === "green" ? "bg-green" : p.color === "gold" ? "bg-gold !text-ink" : "bg-red"]}><Icon name={p.icon} class="w-7 h-7" /></span>
          </div>
          <div>
            <span class:list={[
              "inline-block text-xs font-display font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full text-white mb-4",
              p.color === "green" ? "bg-green" : p.color === "gold" ? "bg-gold !text-ink" : "bg-red",
            ]}>Pôle {i + 1}</span>
            <h2 class="font-display font-bold text-2xl md:text-3xl leading-tight">{p.name}</h2>
            <p class="mt-3 text-lg font-medium text-red">{p.baseline}</p>
            <p class="mt-4 prose-cb">{p.text}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <PatternBand height={24} />

  <!-- Méthode d'impact -->
  <section class="bg-paper-cool">
    <div class="container-cb py-16 md:py-20">
      <div class="text-center mb-4"><Eyebrow label="Notre méthode" /></div>
      <p class="section-title">Une méthode fondée sur <strong>l'action</strong></p>
      <p class="mt-5 text-center text-ink-mute max-w-2xl mx-auto">
        Chaque projet suit une démarche structurée, cohérente et centrée sur les besoins réels.
      </p>
      <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-4">
        {methode.map((m, i) => (
          <div class="bg-white border border-hairline rounded-xl p-6 reveal">
            <span class="font-display font-extrabold text-2xl text-green">{String(i + 1).padStart(2, "0")}</span>
            <p class="mt-2 font-display font-semibold text-lg">{m}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Engagements -->
  <section class="bg-white">
    <div class="container-cb py-16 md:py-20 grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5 reveal">
        <p class="section-title left">Ce à quoi nous nous <strong>engageons</strong></p>
        <p class="mt-5 prose-cb">
          Nos engagements ne sont pas de simples principes : ils constituent le fondement de
          notre identité et orientent chacune de nos décisions.
        </p>
      </div>
      <ul class="md:col-span-7 space-y-3 reveal">
        {engagements.map((e) => (
          <li class="flex gap-3 bg-paper-warm border border-hairline rounded-xl p-4">
            <Icon name="check" class="w-5 h-5 text-green shrink-0 mt-0.5" />
            <span class="text-ink-soft">{e}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
