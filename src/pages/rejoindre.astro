---
import Layout from "~/components/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import Icon from "~/components/Icon.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import MotifTexture from "~/components/MotifTexture.astro";
import PatternBand from "~/components/PatternBand.astro";
import { useTranslations, getLangFromUrl } from "~/i18n/ui";
import { getJoin } from "~/i18n/rejoindre";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const j = getJoin(lang);

const engIcons = ["users", "hand-heart", "graduation-cap", "bulb", "briefcase", "scale"];
const engChips = ["bg-terra/12 text-terra", "bg-emerald/12 text-emerald", "bg-gold/15 text-gold"];
---

<Layout title={t("nav.join")} description={j.hero.subtitle} image="/images/cb/team-clean-hope.jpg">
  <PageHero
    image="/images/cb/team-clean-hope.jpg"
    kicker={j.hero.kicker}
    title={j.hero.title}
    subtitle={j.hero.subtitle}
  />

  <!-- Pourquoi -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <Eyebrow label={j.why.eyebrow} />
        <h2 class="mt-6 section-title left">{j.why.title} <strong>{j.why.strong}</strong></h2>
        <p class="mt-5 prose-cb">{j.why.lead}</p>
        <a href="#adhesion" class="btn btn-terra mt-6">{j.why.cta} <Icon name="arrow-right" class="w-4 h-4" /></a>
      </div>
      <div class="reveal relative rounded-[2rem] overflow-hidden shadow-xl">
        <img src="/images/cb/youth-celebrating.jpg" alt="Communauté Cœurs Braves" class="w-full object-cover aspect-[4/3]" loading="lazy" />
        <div class="absolute bottom-0 left-0 right-0"><PatternBand height={18} /></div>
      </div>
    </div>
  </section>

  <!-- Communauté ouverte à tous -->
  <section class="bg-cream-2">
    <div class="container-cb py-20 md:py-24">
      <div class="text-center"><Eyebrow label={j.who.eyebrow} align="center" /></div>
      <h2 class="mt-6 section-title">{j.who.title} <strong>{j.who.strong}</strong></h2>
      <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {j.who.profils.map((p, i) => (
          <div class="bg-cream border border-hairline rounded-2xl p-6 card-hover reveal">
            <span class="font-display font-700 text-terra text-lg" style="font-weight:700">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="mt-2 font-display font-700 text-base" style="font-weight:700">{p.t}</h3>
            <p class="mt-2 text-sm text-ink-mute leading-relaxed">{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formes d'engagement -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24">
      <div class="text-center"><Eyebrow label={j.engage.eyebrow} align="center" /></div>
      <h2 class="mt-6 section-title">{j.engage.title} <strong>{j.engage.strong}</strong></h2>
      <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {j.engage.types.map((e, i) => (
          <div class="bg-cream border border-hairline rounded-2xl p-7 card-hover reveal">
            <span class:list={["icon-chip w-14 h-14", engChips[i % 3]]}><Icon name={engIcons[i % engIcons.length]} class="w-7 h-7" /></span>
            <h3 class="mt-5 font-display font-700 text-lg" style="font-weight:700">{e.title}</h3>
            <p class="mt-2 text-sm text-ink-mute leading-relaxed">{e.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Parcours -->
  <section class="bg-cream-2">
    <div class="container-cb py-20 md:py-24">
      <div class="text-center"><Eyebrow label={j.parcours.eyebrow} align="center" /></div>
      <h2 class="mt-6 section-title">{j.parcours.title} <strong>{j.parcours.strong}</strong></h2>
      <div class="mt-14 grid md:grid-cols-3 gap-5">
        {j.parcours.steps.map((p, i) => (
          <div class="bg-cream border border-hairline rounded-2xl p-7 reveal">
            <span class="icon-chip w-11 h-11 bg-terra text-white font-display font-700 text-lg" style="font-weight:700">{i + 1}</span>
            <p class="mt-4 text-ink-soft leading-relaxed">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PatternBand height={24} />

  <!-- Formulaire (forêt) -->
  <section id="adhesion" class="relative bg-forest overflow-hidden">
    <MotifTexture class="text-white/[0.05]" />
    <div class="relative container-cb py-20 md:py-24">
      <div class="max-w-2xl mx-auto">
        <div class="text-center text-white">
          <Eyebrow label={j.form.eyebrow} align="center" light />
          <h2 class="mt-6 display-xl !text-white" style="font-size:clamp(1.9rem,4vw,3rem)">{j.form.title} <span class="text-terra-bright">{j.form.accent}</span></h2>
          <p class="mt-4 text-white/70">{j.form.lead}</p>
        </div>
        <form class="cb-form mt-10 bg-cream rounded-[1.6rem] p-7 md:p-9 grid sm:grid-cols-2 gap-4" data-subject="Demande d'adhésion Cœurs Braves">
          <input required placeholder={t("form.name")} class="rounded-xl border border-hairline px-4 py-3 outline-none focus:border-terra bg-white" />
          <input required type="email" placeholder={t("form.email")} class="rounded-xl border border-hairline px-4 py-3 outline-none focus:border-terra bg-white" />
          <input placeholder={t("form.country")} class="rounded-xl border border-hairline px-4 py-3 outline-none focus:border-terra bg-white" />
          <select data-label={j.form.profilLabel} class="rounded-xl border border-hairline px-4 py-3 outline-none focus:border-terra text-ink-mute bg-white">
            <option>{j.form.selectPlaceholder}</option>
            {j.engage.types.map((e) => <option>{e.title}</option>)}
          </select>
          <textarea placeholder={j.form.message} rows="4" class="sm:col-span-2 rounded-xl border border-hairline px-4 py-3 outline-none focus:border-terra bg-white"></textarea>
          <button type="submit" class="btn btn-terra sm:col-span-2">{j.form.submit} <Icon name="arrow-right" class="w-4 h-4" /></button>
        </form>
      </div>
    </div>
  </section>
</Layout>
