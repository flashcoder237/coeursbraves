---
import Layout from "~/components/Layout.astro";
import Icon from "~/components/Icon.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import PatternBand from "~/components/PatternBand.astro";
import MotifTexture from "~/components/MotifTexture.astro";
import Motif from "~/components/Motif.astro";
import { stats, poles, domaines, actualites, temoignages, site } from "~/data/site";

const featured = actualites.find((a) => a.featured)!;
const rest = actualites.filter((a) => !a.featured).slice(0, 4);

const partenaires = ["Seed Fund", "Diaspora Connect", "Institut de Formation de Yaoundé", "Tech4Africa", "Brave Djamal Foundation", "Clean Hope Center"];

// couleur d'accent d'icône par pôle
const poleAccent: Record<string, string> = {
  academy: "terra", fermiers: "emerald", "assaa-technologies": "terra",
  "technology-center": "gold", "immigration-services": "feature", "la-marmite": "emerald",
};
const chipClass = (c: string) =>
  c === "emerald" ? "bg-emerald/15 text-emerald"
  : c === "gold" ? "bg-gold/15 text-gold"
  : "bg-terra/15 text-terra";
---

<Layout
  title={site.name}
  description="Cœurs Braves — association internationale africaine qui investit dans l'humain pour créer des opportunités durables au Cameroun, en République centrafricaine, en Allemagne et dans la diaspora."
>
  <!-- ============ HERO ============ -->
  <section class="bg-cream overflow-hidden">
    <div class="container-cb pt-16 pb-20 md:pt-24 md:pb-28 grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      <div class="lg:col-span-6">
        <span class="badge">Une communauté en action</span>
        <h1 class="display-xl mt-7">
          Investir dans <span class="accent">l'humain.</span>
        </h1>
        <p class="mt-7 text-ink-mute text-lg md:text-xl leading-relaxed max-w-xl">
          Chez Cœurs Braves, nous croyons qu'un changement durable naît de la transmission
          des compétences, de l'entrepreneuriat et de la coopération.
        </p>
        <div class="mt-9 flex flex-wrap gap-3">
          <a href="/rejoindre/" class="btn btn-terra">Rejoindre la communauté</a>
          <a href="/ecosysteme/" class="btn btn-outline">Découvrir notre mission</a>
        </div>
      </div>
      <div class="lg:col-span-6 relative">
        <div class="relative rounded-[2rem] overflow-hidden aspect-[4/3.4] shadow-2xl">
          <img src="/images/cb/hero-community.jpg" alt="La communauté Cœurs Braves réunie" width="1672" height="941" fetchpriority="high" class="w-full h-full object-cover" />
          <div class="absolute bottom-0 left-0 right-0"><PatternBand height={20} /></div>
        </div>
        <div class="absolute -bottom-6 -left-4 sm:left-6 bg-cream rounded-2xl shadow-xl px-6 py-4 flex items-center gap-4 border border-hairline">
          <span class="icon-chip bg-terra/15 text-terra w-11 h-11"><Icon name="users" class="w-6 h-6" /></span>
          <div>
            <div class="font-display font-700 text-2xl leading-none" style="font-weight:700">3 500+</div>
            <div class="text-ink-mute text-xs mt-1">membres engagés</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MARQUEE PARTENAIRES ============ -->
  <section class="bg-cream border-t border-hairline py-8 overflow-hidden">
    <div class="marquee-track gap-16 px-8">
      {[...partenaires, ...partenaires].map((p) => (
        <span class="font-display text-xl md:text-2xl text-ink/25 whitespace-nowrap" style="font-weight:600">{p}</span>
      ))}
    </div>
  </section>

  <!-- Bande kente -->
  <PatternBand height={26} />

  <!-- ============ MANIFESTE (vert forêt) ============ -->
  <section class="relative bg-forest text-white overflow-hidden">
    <MotifTexture class="text-white/[0.06]" />
    <div class="relative container-cb py-24 md:py-32">
      <Eyebrow label="Le manifeste" light />
      <div class="mt-8 grid lg:grid-cols-12 gap-10 items-end">
        <h2 class="lg:col-span-8 display-xl !text-white" style="font-size:clamp(2.2rem,5vw,4.2rem)">
          Nous croyons en la force de celles et ceux qui <span class="text-terra-bright">osent agir.</span>
        </h2>
        <div class="lg:col-span-4 text-white/70 leading-relaxed">
          <p>Un talent peut changer une famille. Une idée peut transformer une communauté.
          Une personne accompagnée aujourd'hui peut devenir le mentor de demain.</p>
          <p class="mt-4 text-white font-medium">Bienvenue au sein de Cœurs Braves.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CHIFFRES ============ -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">
        {stats.map((s) => (
          <div class="reveal">
            <div class="stat-num text-terra">{s.num}</div>
            <p class="mt-4 text-ink-soft leading-snug max-w-[15rem]">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ ÉCOSYSTÈME (bento sombre) ============ -->
  <section class="relative bg-ink text-white overflow-hidden">
    <MotifTexture class="text-white/[0.04]" />
    <div class="relative container-cb py-24 md:py-28">
      <div class="max-w-2xl">
        <Eyebrow label="Notre écosystème" light />
        <h2 class="mt-6 display-xl !text-white" style="font-size:clamp(2rem,4.5vw,3.6rem)">
          Un écosystème au service du <span class="text-terra-bright">développement.</span>
        </h2>
        <p class="mt-5 text-white/60 text-lg leading-relaxed">
          Cœurs Braves réunit plusieurs pôles complémentaires qui collaborent pour accompagner
          les personnes et soutenir les projets.
        </p>
      </div>

      <div class="mt-14 grid md:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-fr">
        {poles.map((p) => {
          const accent = poleAccent[p.slug] ?? "terra";
          const feature = accent === "feature";
          return (
            <a href="/ecosysteme/"
              class:list={[
                "pole-card group relative overflow-hidden rounded-2xl p-7 flex flex-col reveal transition-colors",
                p.slug === "academy" && "lg:row-span-2",
                feature ? "bg-terra hover:bg-terra-dark lg:col-span-2" : "bg-white/[0.04] hover:bg-white/[0.07] border border-white/10",
              ]}
            >
              {p.slug === "academy" && (
                <Fragment>
                  <img src={p.image} alt="" width="1080" height="810"
                    class="absolute inset-0 w-full h-full object-cover opacity-30 transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                  <span class="absolute inset-0 bg-gradient-to-t from-ink via-ink/90 to-ink/35"></span>
                </Fragment>
              )}
              <span class="pole-arrow" aria-hidden="true">↗</span>
              <span class:list={["relative z-10 icon-chip w-14 h-14 mb-auto", feature ? "bg-white/20 text-white" : chipClass(accent)]}>
                <Icon name={p.icon} class="w-7 h-7" />
              </span>
              <div class:list={["relative z-10", p.slug === "academy" ? "mt-24" : "mt-10"]}>
                <h3 class="font-display font-700 text-xl leading-snug" style="font-weight:700">{p.name}</h3>
                <p class:list={["mt-2 text-sm leading-relaxed", feature ? "text-white/85" : "text-white/55"]}>{p.baseline}</p>
                {(p.slug === "academy" || feature) && (
                  <p class:list={["mt-3 text-sm leading-relaxed", feature ? "text-white/70" : "text-white/45"]}>{p.text}</p>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============ DOMAINES D'ACTION ============ -->
  <section class="bg-cream">
    <div class="container-cb py-24 grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-6">
        <Eyebrow label="Nos domaines d'action" />
        <h2 class="mt-6 section-title left">Des secteurs essentiels au <strong>développement humain.</strong></h2>
        <p class="mt-5 prose-cb max-w-lg">
          Chaque programme est conçu pour favoriser l'autonomie, la création de valeur
          et l'impact durable.
        </p>
        <div class="mt-7 flex flex-wrap gap-2.5">
          {domaines.map((d, i) => {
            const accent = ["var(--color-terra)", "var(--color-emerald)", "var(--color-gold)"][i % 3];
            return (
              <span class="domaine-chip" style={`--a:${accent}`}>
                <span class="dot"></span>{d}
              </span>
            );
          })}
        </div>
      </div>
      <div class="lg:col-span-6 grid grid-cols-2 gap-4">
        <img src="/images/cb/training-sewing.jpg" alt="Atelier de couture" width="1672" height="941" class="rounded-2xl h-56 w-full object-cover" loading="lazy" />
        <img src="/images/cb/agri-cacao.jpg" alt="Agriculture" width="2048" height="1365" class="rounded-2xl h-56 w-full object-cover mt-8" loading="lazy" />
        <img src="/images/cb/health-care.jpg" alt="Santé communautaire" width="2048" height="1365" class="rounded-2xl h-56 w-full object-cover" loading="lazy" />
        <img src="/images/cb/youth-laptop-1.jpg" alt="Formation numérique" width="1265" height="844" class="rounded-2xl h-56 w-full object-cover mt-8" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ============ SUR LE TERRAIN ============ -->
  <section class="bg-cream-2">
    <div class="container-cb py-24">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <Eyebrow label="Nos actions" />
          <h2 class="mt-6 section-title left">En direct du <strong>terrain.</strong></h2>
        </div>
        <a href="/ecosysteme/" class="arrow-link">Voir toutes nos actions</a>
      </div>
      <div class="mt-12 grid lg:grid-cols-3 gap-5">
        <a href="/ecosysteme/" class="action-card group relative lg:row-span-2 rounded-2xl overflow-hidden min-h-[360px] reveal">
          <img src={featured.image} alt={featured.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          <span class="action-scrim"></span>
          <div class="relative h-full flex flex-col justify-end p-7 text-white">
            <span class="action-tag mb-4">{featured.tag}</span>
            <h3 class="font-display font-700 text-2xl md:text-[1.75rem] leading-tight" style="font-weight:700;text-shadow:0 2px 18px rgba(0,0,0,0.35)">{featured.title}</h3>
            <p class="mt-2.5 text-white/90 text-[0.95rem] leading-relaxed max-w-md" style="text-shadow:0 1px 12px rgba(0,0,0,0.4)">{featured.excerpt}</p>
            <span class="action-more mt-4">Lire l'article <span class="action-arrow">→</span></span>
          </div>
        </a>
        {rest.map((a) => (
          <a href="/ecosysteme/" class="action-card group relative rounded-2xl overflow-hidden min-h-[200px] reveal">
            <img src={a.image} alt={a.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <span class="action-scrim"></span>
            <div class="relative h-full flex flex-col justify-end p-5 text-white">
              <span class="action-tag mb-2.5">{a.tag}</span>
              <h3 class="font-display font-700 text-[1.05rem] leading-snug" style="font-weight:700;text-shadow:0 2px 14px rgba(0,0,0,0.4)">{a.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PRÉSENCE (split image + forêt) ============ -->
  <section class="bg-cream">
    <div class="container-cb py-24 grid lg:grid-cols-2 gap-12 items-stretch">
      <div class="rounded-[2rem] overflow-hidden min-h-[340px]">
        <img src="/images/cb/children-flag.jpg" alt="Communauté au Cameroun" width="1080" height="810" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="relative overflow-hidden bg-forest text-white rounded-[2rem] p-10 md:p-12 flex flex-col justify-center">
        <MotifTexture class="text-white/[0.06]" />
        <div class="relative">
        <Eyebrow label="Une présence internationale" light />
        <h2 class="mt-6 display-xl !text-white" style="font-size:clamp(1.9rem,3.8vw,2.8rem)">
          Du Cameroun à la diaspora.
        </h2>
        <p class="mt-4 text-white/70 leading-relaxed">
          Notre communauté rassemble des membres au Cameroun, en République centrafricaine,
          en Allemagne et au sein de la diaspora africaine.
        </p>
        <div class="mt-8 grid grid-cols-2 gap-3">
          {site.countries.map((c) => (
            <div class="presence-tile flex items-center gap-3 bg-white/5 border border-white/10 rounded-xl px-4 py-3">
              <Icon name="map-pin" class="w-5 h-5 text-terra-bright shrink-0" />
              <span class="text-sm font-medium">{c}</span>
            </div>
          ))}
        </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ NOTRE IDENTITÉ (affiches) ============ -->
  <section class="relative bg-ink text-white overflow-hidden">
    <MotifTexture class="text-white/[0.04]" />
    <Motif name="eye" class="absolute -right-20 -top-20 w-80 h-80 text-white/[0.05] hidden md:block" />
    <Motif name="star" class="absolute -left-16 bottom-8 w-64 h-64 text-white/[0.04] hidden md:block" />
    <div class="relative container-cb py-24 md:py-28">
      <div class="max-w-2xl mx-auto text-center">
        <div class="flex justify-center"><Eyebrow label="Notre identité" light align="center" /></div>
        <h2 class="mt-6 display-xl !text-white" style="font-size:clamp(2rem,4.5vw,3.6rem)">
          Fiers de nos racines, tournés vers <span class="text-terra-bright">l'avenir.</span>
        </h2>
        <p class="mt-5 text-white/60 text-lg leading-relaxed">
          Du Cameroun à l'Allemagne, notre communauté tisse un pont entre les nations.
          Une même fierté, une même ambition : investir dans l'humain.
        </p>
      </div>
      <div class="mt-14 grid sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <figure class="group reveal">
          <div class="rounded-2xl overflow-hidden ring-1 ring-white/10">
            <img src="/images/cb/poster-cameroun.png" alt="Cœurs Braves — Cameroun" width="1080" height="1080" class="w-full aspect-square object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" />
          </div>
          <figcaption class="mt-3 flex items-center gap-2 text-sm text-white/70">
            <span class="w-2 h-2 rounded-full bg-terra"></span>Cameroun · nos racines
          </figcaption>
        </figure>
        <figure class="group reveal">
          <div class="rounded-2xl overflow-hidden ring-1 ring-white/10">
            <img src="/images/cb/poster-allemagne.png" alt="Cœurs Braves — Allemagne, diaspora" width="1080" height="1080" class="w-full aspect-square object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" />
          </div>
          <figcaption class="mt-3 flex items-center gap-2 text-sm text-white/70">
            <span class="w-2 h-2 rounded-full bg-emerald"></span>Allemagne · notre diaspora
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============ TÉMOIGNAGES ============ -->
  <section class="bg-cream-2">
    <div class="container-cb py-24">
      <div class="text-center"><Eyebrow label="Témoignages" align="center" /></div>
      <h2 class="mt-6 section-title">Ils racontent leur <strong>parcours.</strong></h2>
      <div class="mt-14 grid md:grid-cols-2 gap-6">
        {temoignages.map((t, i) => {
          const ring = ["ring-terra/70", "ring-emerald/70", "ring-gold/70", "ring-terra/70"][i % 4];
          const dot = ["bg-terra", "bg-emerald", "bg-gold", "bg-terra"][i % 4];
          return (
          <figure
            class="testimonial reveal group relative bg-cream rounded-[1.4rem] p-8 border border-hairline flex flex-col"
            style={`transition-delay:${i * 90}ms`}
          >
            <svg class="testimonial-quote" viewBox="0 0 40 40" aria-hidden="true">
              <path d="M17 8c-5 2-9 7-9 14v10h11V21h-6c0-4 2-7 5-8Zm17 0c-5 2-9 7-9 14v10h11V21h-6c0-4 2-7 5-8Z" fill="currentColor"/>
            </svg>
            <blockquote class="relative text-ink-soft text-[1.12rem] leading-relaxed flex-1">{t.quote}</blockquote>
            <figcaption class="mt-7 flex items-center gap-4 pt-6 border-t border-hairline/70">
              <span class:list={["shrink-0 rounded-full ring-2 ring-offset-2 ring-offset-cream overflow-hidden", ring]}>
                <img src={t.photo} alt={t.name} class="object-cover" style="width:3.4rem;height:3.4rem" loading="lazy" />
              </span>
              <div class="min-w-0">
                <div class="font-display font-700 text-ink leading-tight" style="font-weight:700">{t.name}</div>
                <div class="mt-0.5 flex items-center gap-2 text-sm text-ink-mute">
                  <span class:list={["w-1.5 h-1.5 rounded-full shrink-0", dot]}></span>
                  <span class="truncate">{t.role} · {t.place}</span>
                </div>
              </div>
            </figcaption>
          </figure>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============ NEWSLETTER ============ -->
  <section class="bg-cream">
    <div class="container-cb pb-4">
      <div class="border-t border-hairline pt-16 grid md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="section-title left" style="font-size:clamp(1.6rem,3vw,2.2rem)">Restons en contact.</h2>
          <p class="mt-3 text-ink-mute">Actualités, appels à projets et opportunités, directement dans votre boîte de réception.</p>
        </div>
        <form class="cb-form flex flex-col sm:flex-row gap-3" data-subject="Inscription à la newsletter Cœurs Braves">
          <input type="email" required placeholder="Votre adresse électronique"
            class="flex-1 rounded-full px-6 py-3.5 bg-white border border-hairline text-ink placeholder:text-ink-mute outline-none focus:border-terra" />
          <button type="submit" class="btn btn-terra">S'abonner</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
