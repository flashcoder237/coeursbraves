---
import Layout from "~/components/Layout.astro";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { loadPoles } from "~/lib/poles";
import { loadBranches } from "~/lib/orgs";
import { branchUrl } from "~/lib/urls";
import { getStrings, type Locale } from "~/i18n/strings";

const locale = (Astro.currentLocale as Locale) ?? "fr";
const t = getStrings(locale);
const poles = await loadPoles(locale);
const poleLinks = poles.map((p) => ({ nom: p.nom, slug: p.slug }));
const branches = await loadBranches(locale);

const typeLabels: Record<string, Record<Locale, string>> = {
  association: { fr: "Association", en: "Association", de: "Verein" },
  verein: { fr: "Verein", en: "Verein", de: "Verein" },
  label: { fr: "Label", en: "Label", de: "Label" },
  apparel: { fr: "Apparel", en: "Apparel", de: "Apparel" },
  foundation: { fr: "Fondation", en: "Foundation", de: "Stiftung" },
  media: { fr: "Médias", en: "Media", de: "Medien" },
  autre: { fr: "Autre", en: "Other", de: "Andere" },
};

const meta = {
  fr: { title: "Branches — Cœurs Braves", description: "Les sous-organisations de Cœurs Braves : Association, Verein, Music, Apparel et plus." },
  en: { title: "Branches — Cœurs Braves", description: "The sub-organisations of Cœurs Braves: Association, Verein, Music, Apparel and more." },
  de: { title: "Zweige — Cœurs Braves", description: "Die Sub-Organisationen von Cœurs Braves: Verein, Music, Apparel und mehr." },
};
const m = meta[locale];
---

<Layout title={m.title} description={m.description} locale={locale}>
  <Nav locale={locale} />
  <main class="pt-32 pb-24 px-4 md:px-8 max-w-[1400px] mx-auto">
    <header class="mb-16 reveal max-w-3xl">
      <p class="font-mono text-[11px] uppercase tracking-widest text-ink-soft mb-6">{t.branches.sectionLabel}</p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-semibold tracking-tightest leading-[0.95] text-balance mb-6">
        {t.branches.title}
      </h1>
      <p class="text-lg md:text-xl text-ink-soft font-light leading-relaxed">{t.branches.intro}</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 reveal">
      {branches.map((b) => {
        const typeLabel = typeLabels[b.data.type]?.[locale] ?? b.data.type;
        return (
          <a href={branchUrl(b.data.slug, locale)} class="group rounded-[1.25rem] border-hairline bg-white overflow-hidden flex flex-col shadow-soft hover:shadow-nav hover:-translate-y-1 transition-all duration-300">
            {b.data.image && (
              <div class="aspect-[4/5] overflow-hidden bg-paper-dark">
                <img
                  src={b.data.image}
                  alt={b.data.nom}
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-[1.2s]"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6 md:p-7 flex flex-col flex-grow">
              <div class="flex items-center justify-between gap-2 mb-3">
                <span class="font-mono text-[10px] uppercase tracking-widest text-ink-soft">{typeLabel}</span>
                {b.data.pays && (
                  <span class="font-mono text-[10px] uppercase tracking-wider text-ink-soft opacity-70">{b.data.pays}</span>
                )}
              </div>
              <h2 class="text-xl md:text-2xl font-semibold tracking-tight mb-2 text-ink">{b.data.nom}</h2>
              <p class="text-sm text-ink-soft leading-relaxed flex-grow">{b.data.descriptionCourte}</p>
              <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-ink-soft group-hover:text-ink transition-colors">
                <span>{t.branches.discoverLink}</span>
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="13 6 19 12 13 18"></polyline>
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </main>
  <Footer locale={locale} poleLinks={poleLinks} />
</Layout>
