---
import { getCollection, render } from "astro:content";
import Layout from "~/components/Layout.astro";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { loadPoles } from "~/lib/poles";
import { formatArticleDate, categoryLabel } from "~/lib/articles";
import { articleUrl, localePath } from "~/lib/urls";
import { getStrings, type Locale } from "~/i18n/strings";

export async function getStaticPaths() {
  const all = await getCollection("articles", (e) => e.data.brouillon === false);
  const slugs = new Set<string>();
  for (const e of all) {
    const s = e.data.baseSlug ?? e.id.replace(/\.(fr|de|en)$/, "");
    slugs.add(s);
  }
  return [...slugs].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const locale = (Astro.currentLocale as Locale) ?? "fr";
const t = getStrings(locale);

const all = await getCollection("articles", (e) => e.data.brouillon === false);
const candidates = all.filter(
  (e) => (e.data.baseSlug ?? e.id.replace(/\.(fr|de|en)$/, "")) === slug,
);
const entry =
  candidates.find((e) => e.id.endsWith(`.${locale}`)) ??
  candidates.find((e) => e.id.endsWith(`.fr`)) ??
  candidates[0];

if (!entry) return Astro.redirect(localePath("/journal", locale));

const { Content } = await render(entry);
const poles = await loadPoles(locale);
const poleLinks = poles.map((p) => ({ nom: p.nom, slug: p.slug }));

const accentDot =
  entry.data.categorie === "fermiers" || entry.data.categorie === "technology"
    ? "dot-green"
    : entry.data.categorie === "academy" || entry.data.categorie === "studios-tv"
      ? "dot-red"
      : "dot-ochre";

const others = (() => {
  const grouped = new Map<string, typeof all[number][]>();
  for (const e of all) {
    const s = e.data.baseSlug ?? e.id.replace(/\.(fr|de|en)$/, "");
    if (s === slug) continue;
    const arr = grouped.get(s) ?? [];
    arr.push(e);
    grouped.set(s, arr);
  }
  const picked: typeof all[number][] = [];
  for (const [, group] of grouped) {
    const m =
      group.find((e) => e.id.endsWith(`.${locale}`)) ??
      group.find((e) => e.id.endsWith(`.fr`)) ??
      group[0];
    if (m) picked.push(m);
  }
  picked.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return picked.slice(0, 3);
})();
---

<Layout title={`${entry.data.titre} — Cœurs Braves`} description={entry.data.extrait} locale={locale}>
  <Nav locale={locale} />
  <main class="pt-32 pb-24 px-4 md:px-8 max-w-[900px] mx-auto">
    <a
      href={localePath("/journal", locale)}
      class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-widest text-ink-soft hover:text-ink transition-colors mb-12"
    >
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="11 6 5 12 11 18"></polyline>
      </svg>
      <span>{t.journal.title}</span>
    </a>

    <header class="mb-12 reveal">
      <div class="font-mono text-xs uppercase tracking-widest text-ink-soft mb-5 flex items-center gap-3">
        <span class={`dot ${accentDot}`}></span>
        <span>{categoryLabel(entry.data.categorie, locale)}</span>
        <span>·</span>
        <span>{formatArticleDate(entry.data.date, locale)}</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tightest leading-[1.05] text-balance mb-8">
        {entry.data.titre}
      </h1>
      <p class="text-lg md:text-xl text-ink-soft font-light leading-relaxed">{entry.data.extrait}</p>
      <p class="mt-6 font-mono text-[11px] uppercase tracking-widest text-ink-soft">{entry.data.auteur}</p>
    </header>

    <div class="aspect-[16/9] rounded-[1rem] overflow-hidden mb-12 border border-black/5 shadow-soft reveal">
      <img src={entry.data.imageCouverture} alt={entry.data.titre} class="w-full h-full object-cover" loading="eager" />
    </div>

    <article class="reveal prose prose-neutral max-w-none font-sans text-lg leading-relaxed text-ink-soft prose-headings:font-semibold prose-headings:text-ink prose-headings:tracking-tight prose-h2:text-2xl md:prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4 prose-p:my-4 prose-strong:text-ink">
      <Content />
    </article>

    {others.length > 0 && (
      <section class="mt-24 pt-12 border-t border-hairline reveal">
        <p class="font-mono text-[10px] uppercase tracking-widest text-ink-soft mb-6">{t.journal.seeAll}</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {others.map((o) => {
            const s = o.data.baseSlug ?? o.id.replace(/\.(fr|de|en)$/, "");
            return (
              <a href={articleUrl(s, locale)} class="group block">
                <div class="aspect-[4/3] rounded-[0.75rem] overflow-hidden mb-3 border border-black/5">
                  <img src={o.data.imageCouverture} alt={o.data.titre} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[0.8s]" loading="lazy" />
                </div>
                <div class="font-mono text-[10px] text-ink-soft mb-1">{formatArticleDate(o.data.date, locale)}</div>
                <h3 class="text-base md:text-lg font-medium tracking-tight text-ink leading-snug">{o.data.titre}</h3>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </main>
  <Footer locale={locale} poleLinks={poleLinks} />
</Layout>
