---
import Layout from "~/components/Layout.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import Icon from "~/components/Icon.astro";
import MotifTexture from "~/components/MotifTexture.astro";
import PatternBand from "~/components/PatternBand.astro";
import { render } from "astro:content";
import { useTranslations, getLangFromUrl, localizePath } from "~/i18n/ui";
import { getArticle, getJournal, getJournalSlugs } from "~/i18n/content";

export async function getStaticPaths() {
  const slugs = await getJournalSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

type Props = Record<string, never>;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);
const { slug } = Astro.params;

const entry = await getArticle(slug!, lang);
const { Content } = await render(entry!);
const article = entry!.data;

const related = (await getJournal(lang)).filter((a) => a.slug !== slug).slice(0, 3);
---

<Layout title={article.title} description={article.excerpt}>
  <!-- En-tête -->
  <header class="relative flex items-end min-h-[52vh] overflow-hidden">
    <img src={article.image} alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/75 to-forest/30"></div>
    <MotifTexture class="text-white/[0.07]" />
    <div class="relative container-cb pb-16 pt-36 text-white max-w-4xl">
      <span class="badge badge-light mb-5">{article.category}</span>
      <h1 class="display-xl !text-white" style="font-size:clamp(2.2rem,5vw,4rem)">{article.title}</h1>
      <div class="mt-5 flex items-center gap-3 text-white/75 text-sm">
        <time datetime={article.iso}>{article.date}</time>
        {article.source && (<><span class="w-1 h-1 rounded-full bg-white/40"></span><span>{article.source}</span></>)}
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0"><PatternBand height={20} /></div>
  </header>

  <!-- Corps -->
  <article class="bg-cream">
    <div class="container-cb py-16 md:py-20 max-w-3xl">
      <p class="text-xl md:text-2xl leading-relaxed font-display text-ink" style="font-weight:500;letter-spacing:-0.01em">{article.excerpt}</p>
      <div class="article-body mt-10">
        <Content />
      </div>

      {article.gallery && (
        <div class="mt-10 grid grid-cols-2 gap-3 sm:gap-4">
          {article.gallery.map((g) => (
            <div class="rounded-xl overflow-hidden">
              <img src={g.src} alt={g.alt} class="w-full aspect-[16/10] object-cover hover:scale-[1.03] transition-transform duration-500" loading="lazy" />
            </div>
          ))}
        </div>
      )}

      <div class="mt-12 pt-8 border-t border-hairline flex flex-wrap items-center justify-between gap-4">
        <a href={L("/journal/")} class="inline-flex items-center gap-2 font-display font-600 text-ink hover:text-terra transition-colors" style="font-weight:600"><span class="text-lg">←</span> {t("journal.all_articles")}</a>
        <a href={L("/soutenir/")} class="btn btn-terra text-sm">{t("cta.support")} <Icon name="heart" class="w-4 h-4" /></a>
      </div>
    </div>
  </article>

  <!-- À lire aussi -->
  {related.length > 0 && (
    <section class="bg-cream-2">
      <div class="container-cb py-20">
        <div class="text-center"><Eyebrow label={t("journal.related")} align="center" /></div>
        <h2 class="mt-6 section-title">{t("journal.related_title")}</h2>
        <div class="mt-12 grid sm:grid-cols-3 gap-6">
          {related.map((a) => (
            <a href={L(`/journal/${a.slug}/`)} class="group bg-cream rounded-2xl overflow-hidden border border-hairline flex flex-col card-hover">
              <div class="relative h-44 overflow-hidden">
                <img src={a.data.image} alt={a.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                <span class="absolute top-4 left-4 text-[0.66rem] uppercase tracking-[0.16em] font-display font-700 px-3 py-1.5 rounded-full bg-cream/90 text-terra" style="font-weight:700">{a.data.category}</span>
              </div>
              <div class="p-5 flex flex-col flex-1">
                <time datetime={a.data.iso} class="text-xs text-ink-mute">{a.data.date}</time>
                <h3 class="mt-1.5 font-display font-700 text-base leading-snug" style="font-weight:700">{a.data.title}</h3>
                <span class="arrow-link mt-3 text-sm">{t("journal.read_short")}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
