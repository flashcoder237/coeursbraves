---
import Layout from "~/components/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import { partnershipTypes } from "~/data/site";

const domaines = [
  { t: "Développement des compétences", d: "Co-construction de programmes de formation, ateliers, conférences et mentorat." },
  { t: "Entrepreneuriat", d: "Accompagnement des porteurs de projets, incubation, accélération et développement." },
  { t: "Technologies et innovation", d: "Conception de solutions numériques, projets technologiques et recherche appliquée." },
  { t: "Agriculture", d: "Développement de projets agricoles, sécurité alimentaire et innovation rurale." },
  { t: "Santé communautaire", d: "Campagnes de sensibilisation, prévention et actions communautaires." },
  { t: "Éducation", d: "Promotion de l'apprentissage, de l'orientation et de l'accès aux compétences." },
  { t: "Investissement", d: "Mobilisation de ressources et soutien aux projets à fort impact." },
  { t: "Recherche & développement", d: "Production de connaissances, études, expérimentations et innovation sociale." },
];

const contributions = [
  "Développer les compétences des jeunes",
  "Accompagner les entrepreneurs",
  "Favoriser l'innovation",
  "Soutenir l'agriculture durable",
  "Promouvoir l'éducation et la formation",
  "Renforcer les initiatives communautaires",
  "Créer des emplois",
  "Générer un impact durable",
];
---

<Layout title="Devenir partenaire" description="Entreprises, fondations, universités, institutions et investisseurs : construisons ensemble des solutions à fort impact avec Cœurs Braves.">
  <PageHero
    image="/images/cb/partners-meeting.jpg"
    kicker="Devenir partenaire"
    title="Les plus grands changements se construisent ensemble"
    subtitle="En mettant en commun nos compétences, nos ressources et nos expériences, nous créons des solutions à fort impact."
  />

  <!-- Pourquoi -->
  <section class="bg-white">
    <div class="container-cb py-16 md:py-20 grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-6 reveal">
        <p class="section-title left">Pourquoi devenir <strong>partenaire ?</strong></p>
        <p class="mt-5 prose-cb">
          Un partenariat avec Cœurs Braves, c'est rejoindre un écosystème engagé dans le
          développement des personnes et des territoires. Nos partenariats sont fondés sur une
          vision commune, la confiance et la recherche de résultats concrets.
        </p>
      </div>
      <ul class="md:col-span-6 grid sm:grid-cols-2 gap-3 reveal">
        {contributions.map((c) => (
          <li class="flex items-center gap-3 bg-paper-warm border border-hairline rounded-xl px-4 py-3">
            <span class="w-2.5 h-2.5 rounded-full bg-gold shrink-0"></span>
            <span class="text-sm text-ink-soft">{c}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Domaines de collaboration -->
  <section class="bg-paper-cool">
    <div class="container-cb py-16 md:py-20">
      <p class="section-title">Nos domaines de <strong>collaboration</strong></p>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {domaines.map((d) => (
          <div class="bg-white border border-hairline rounded-2xl p-6 card-hover reveal">
            <h3 class="font-display font-bold text-base">{d.t}</h3>
            <p class="mt-2 text-sm text-ink-mute leading-relaxed">{d.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formes de partenariat -->
  <section class="bg-white">
    <div class="container-cb py-16 md:py-20">
      <p class="section-title">Les formes de <strong>partenariat</strong></p>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {partnershipTypes.map((p, i) => (
          <div class:list={[
            "rounded-2xl p-7 text-white reveal",
            i % 3 === 0 ? "bg-green" : i % 3 === 1 ? "bg-red" : "bg-ink",
          ]}>
            <h3 class="font-display font-bold text-lg">{p.title}</h3>
            <p class="mt-2 text-white/85 text-sm leading-relaxed">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-paper-warm">
    <div class="container-cb py-16 text-center max-w-2xl">
      <p class="section-title">Ensemble, développons des solutions à <strong>fort impact</strong></p>
      <p class="mt-5 prose-cb">
        Entreprise, fondation, université, institution publique, organisation internationale,
        investisseur, incubateur, média ou expert : construisons ensemble des projets créateurs
        d'opportunités.
      </p>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <a href="/contact/" class="btn btn-red">Contacter l'équipe Partenariats</a>
        <a href="/soutenir/" class="btn btn-outline">Découvrir le mécénat</a>
      </div>
    </div>
  </section>
</Layout>
