---
import { getCollection, render } from "astro:content";
import Layout from "~/components/Layout.astro";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { loadPoles } from "~/lib/poles";
import { localePath, partnerUrl } from "~/lib/urls";
import { getStrings, type Locale } from "~/i18n/strings";

export async function getStaticPaths() {
  const all = await getCollection("partners");
  const slugs = new Set<string>(all.map((e) => e.data.slug));
  return [...slugs].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const locale = (Astro.currentLocale as Locale) ?? "fr";
const t = getStrings(locale);

const all = await getCollection("partners");
const candidates = all.filter((e) => e.data.slug === slug);
const entry =
  candidates.find((e) => e.id.endsWith(`.${locale}`)) ??
  candidates.find((e) => e.id.endsWith(`.fr`)) ??
  candidates[0];

if (!entry) return Astro.redirect(localePath("/", locale));

const { Content } = await render(entry);
const poles = await loadPoles(locale);
const poleLinks = poles.map((p) => ({ nom: p.nom, slug: p.slug }));

const typeLabels: Record<string, Record<Locale, string>> = {
  institutionnel: { fr: "Institutionnel", en: "Institutional", de: "Institutionell" },
  financier: { fr: "Financier", en: "Financial", de: "Finanziell" },
  media: { fr: "Médias", en: "Media", de: "Medien" },
  technologique: { fr: "Technologique", en: "Technology", de: "Technologie" },
  academique: { fr: "Académique", en: "Academic", de: "Akademisch" },
  ong: { fr: "ONG", en: "NGO", de: "NGO" },
};
const typeLabel = typeLabels[entry.data.type]?.[locale] ?? entry.data.type;

const others = (() => {
  const grouped = new Map<string, typeof all[number][]>();
  for (const e of all) {
    if (e.data.slug === slug) continue;
    const arr = grouped.get(e.data.slug) ?? [];
    arr.push(e);
    grouped.set(e.data.slug, arr);
  }
  const picked: typeof all[number][] = [];
  for (const [, group] of grouped) {
    const m =
      group.find((e) => e.id.endsWith(`.${locale}`)) ??
      group.find((e) => e.id.endsWith(`.fr`)) ??
      group[0];
    if (m) picked.push(m);
  }
  picked.sort((a, b) => a.data.ordre - b.data.ordre);
  return picked.slice(0, 3);
})();
---

<Layout title={`${entry.data.nom} — Cœurs Braves`} description={entry.data.descriptionCourte ?? ""} locale={locale}>
  <Nav locale={locale} />
  <main class="pt-32 pb-24 px-4 md:px-8 max-w-[1000px] mx-auto">
    <a
      href={localePath("/", locale) + "#partners"}
      class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-widest text-ink-soft hover:text-ink transition-colors mb-12"
    >
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="11 6 5 12 11 18"></polyline>
      </svg>
      <span>{t.partners.title}</span>
    </a>

    <header class="mb-16 reveal">
      <p class="font-mono text-xs uppercase tracking-widest text-ink-soft mb-5">{typeLabel}</p>
      {entry.data.logo && (
        <div class="mb-8 h-20 flex items-center">
          <img src={entry.data.logo} alt={entry.data.nom} class="max-h-full max-w-xs object-contain" loading="eager" />
        </div>
      )}
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tightest leading-[1.05] text-balance mb-8">
        {entry.data.nom}
      </h1>
      {entry.data.descriptionCourte && (
        <p class="text-lg md:text-xl text-ink-soft font-light leading-relaxed max-w-2xl">
          {entry.data.descriptionCourte}
        </p>
      )}
      {entry.data.url && (
        <a
          href={entry.data.url}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-2 bg-ink text-white px-6 py-3 rounded-full text-sm font-medium hover:brightness-110 hover:-translate-y-0.5 transition-all"
        >
          <span>{t.partners.visitLink}</span>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="7" y1="17" x2="17" y2="7"></line>
            <polyline points="9 7 17 7 17 15"></polyline>
          </svg>
        </a>
      )}
    </header>

    <article class="max-w-3xl reveal prose prose-neutral font-sans text-lg leading-relaxed text-ink-soft prose-headings:font-semibold prose-headings:text-ink prose-headings:tracking-tight prose-h2:text-2xl md:prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4 prose-p:my-4 prose-strong:text-ink">
      <Content />
    </article>

    {others.length > 0 && (
      <section class="mt-24 pt-12 border-t border-hairline reveal">
        <p class="font-mono text-[10px] uppercase tracking-widest text-ink-soft mb-6">{t.partners.title}</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {others.map((o) => (
            <a href={partnerUrl(o.data.slug, locale)} class="group block rounded-[1rem] border-hairline bg-white p-6 hover:shadow-nav hover:-translate-y-1 transition-all">
              <span class="font-mono text-[10px] uppercase tracking-widest text-ink-soft">{typeLabels[o.data.type]?.[locale] ?? o.data.type}</span>
              <h3 class="text-lg font-semibold tracking-tight mt-2 mb-2">{o.data.nom}</h3>
              {o.data.descriptionCourte && <p class="text-sm text-ink-soft leading-relaxed">{o.data.descriptionCourte}</p>}
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer locale={locale} poleLinks={poleLinks} />
</Layout>
