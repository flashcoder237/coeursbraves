---
import Layout from "~/components/Layout.astro";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { loadPoles } from "~/lib/poles";
import { loadPartners } from "~/lib/orgs";
import { partnerUrl } from "~/lib/urls";
import { getStrings, type Locale } from "~/i18n/strings";

const locale = (Astro.currentLocale as Locale) ?? "fr";
const t = getStrings(locale);
const poles = await loadPoles(locale);
const poleLinks = poles.map((p) => ({ nom: p.nom, slug: p.slug }));
const partners = await loadPartners(locale);

const typeLabels: Record<string, Record<Locale, string>> = {
  institutionnel: { fr: "Institutionnel", en: "Institutional", de: "Institutionell" },
  financier: { fr: "Financier", en: "Financial", de: "Finanziell" },
  media: { fr: "Médias", en: "Media", de: "Medien" },
  technologique: { fr: "Technologique", en: "Technology", de: "Technologie" },
  academique: { fr: "Académique", en: "Academic", de: "Akademisch" },
  ong: { fr: "ONG", en: "NGO", de: "NGO" },
};

const grouped = new Map<string, typeof partners>();
for (const p of partners) {
  const arr = grouped.get(p.data.type) ?? [];
  arr.push(p);
  grouped.set(p.data.type, arr);
}

const meta = {
  fr: { title: "Partenaires — Cœurs Braves", description: "Les partenaires institutionnels, financiers, médias et technologiques de Cœurs Braves." },
  en: { title: "Partners — Cœurs Braves", description: "The institutional, financial, media and technology partners of Cœurs Braves." },
  de: { title: "Partner — Cœurs Braves", description: "Die institutionellen, finanziellen, Medien- und Technologiepartner von Cœurs Braves." },
};
const m = meta[locale];
---

<Layout title={m.title} description={m.description} locale={locale}>
  <Nav locale={locale} />
  <main class="pt-32 pb-24 px-4 md:px-8 max-w-[1400px] mx-auto">
    <header class="mb-16 reveal max-w-3xl">
      <p class="font-mono text-[11px] uppercase tracking-widest text-ink-soft mb-6">{t.partners.sectionLabel}</p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-semibold tracking-tightest leading-[0.95] text-balance mb-6">
        {t.partners.title}
      </h1>
      <p class="text-lg md:text-xl text-ink-soft font-light leading-relaxed">{t.partners.intro}</p>
    </header>

    {[...grouped.entries()].map(([type, items]) => {
      const typeLabel = typeLabels[type]?.[locale] ?? type;
      return (
        <section class="mb-16 reveal">
          <p class="font-mono text-[10px] uppercase tracking-widest text-ink-soft mb-6 flex items-center gap-2">
            <span class="dot dot-ochre"></span>
            <span>{typeLabel}</span>
          </p>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
            {items.map((p) => (
              <a href={partnerUrl(p.data.slug, locale)} class="group block h-full">
                <div class="h-full rounded-[1rem] border-hairline bg-white p-6 md:p-7 flex flex-col shadow-soft hover:shadow-nav hover:-translate-y-1 transition-all duration-300">
                  {p.data.logo ? (
                    <div class="h-14 mb-4 flex items-center">
                      <img src={p.data.logo} alt={p.data.nom} class="max-h-full max-w-[80%] object-contain grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all" loading="lazy" />
                    </div>
                  ) : (
                    <h3 class="text-lg md:text-xl font-semibold tracking-tight mb-3 text-ink leading-tight">{p.data.nom}</h3>
                  )}
                  {p.data.descriptionCourte && (
                    <p class="text-sm text-ink-soft leading-relaxed flex-grow">{p.data.descriptionCourte}</p>
                  )}
                  <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium font-mono uppercase tracking-widest text-ink-soft group-hover:text-ink transition-colors">
                    <span>{t.partners.visitLink}</span>
                    <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="13 6 19 12 13 18"></polyline>
                    </svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>
  <Footer locale={locale} poleLinks={poleLinks} />
</Layout>
