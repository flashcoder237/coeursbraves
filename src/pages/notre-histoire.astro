---
import Layout from "~/components/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import Motif from "~/components/Motif.astro";
import MotifTexture from "~/components/MotifTexture.astro";
import PatternBand from "~/components/PatternBand.astro";
import { site } from "~/data/site";

const timeline = [
  { t: "La naissance d'une conviction", d: "Les premières réflexions autour d'une organisation dédiée au développement humain et à l'accompagnement des talents." },
  { t: "Les premières actions", d: "Organisation des premiers ateliers, formations et initiatives communautaires." },
  { t: "La structuration de l'écosystème", d: "Création progressive des différentes initiatives et pôles d'activité portés par Cœurs Braves." },
  { t: "L'ouverture à l'international", d: "Développement des activités au Cameroun, en République centrafricaine, en Allemagne et auprès de la diaspora africaine." },
  { t: "Aujourd'hui", d: "Une communauté internationale engagée qui rassemble des milliers de membres autour d'une même vision." },
  { t: "Demain", d: "Accélérer la création d'opportunités, renforcer les partenariats stratégiques et contribuer à l'émergence d'une Afrique plus innovante, inclusive et prospère." },
];

const valeurs = [
  { t: "Courage", d: "Il nous pousse à entreprendre malgré les difficultés.", motif: "star", chip: "bg-terra/15 text-terra", num: "bg-terra" },
  { t: "Solidarité", d: "Les plus grandes réussites se construisent ensemble.", motif: "cross", chip: "bg-emerald/15 text-emerald", num: "bg-emerald" },
  { t: "Impact", d: "Agir avec responsabilité pour des résultats concrets et durables.", motif: "zigzag", chip: "bg-gold/15 text-gold", num: "bg-gold" },
];
---

<Layout title="Notre histoire" description="Une conviction devenue un mouvement : découvrez l'histoire de Cœurs Braves, de sa naissance à son écosystème international.">
  <PageHero
    image="/images/cb/youth-laptop-2.jpg"
    kicker="Notre histoire"
    title="Une conviction devenue un mouvement"
    subtitle="Chaque grande transformation commence par une conviction : croire qu'un avenir meilleur est possible."
  />

  <!-- Intro -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24 grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-7">
        <Eyebrow label="L'origine" />
        <h2 class="mt-6 section-title left">Le potentiel était immense, les opportunités <strong>limitées.</strong></h2>
      </div>
      <div class="lg:col-span-5 prose-cb reveal">
        <p>Pendant des années, nous avons rencontré des jeunes diplômés sans emploi, des entrepreneurs porteurs d'idées prometteuses mais privés de financement, des femmes déterminées à améliorer les conditions de vie de leur famille.</p>
        <p>Le véritable défi n'était pas le manque de talent, mais <strong>l'absence d'un environnement capable d'accompagner, de former, de connecter et d'encourager.</strong> C'est cette réalité qui a donné naissance à Cœurs Braves.</p>
      </div>
    </div>
  </section>

  <PatternBand height={24} />

  <!-- Fondateur (vert forêt) -->
  <section class="relative bg-forest text-white overflow-hidden">
    <MotifTexture class="text-white/[0.06]" />
    <Motif name="eye" class="absolute -right-16 top-1/2 -translate-y-1/2 w-80 h-80 text-white/[0.05] hidden lg:block" />
    <div class="relative container-cb py-20 md:py-24 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <div class="rounded-[2rem] overflow-hidden ring-1 ring-white/10">
          <img src="/images/cb/entrepreneurs-meeting.jpg" alt="Transmission et accompagnement" class="w-full object-cover aspect-[4/3]" loading="lazy" />
        </div>
      </div>
      <div class="reveal">
        <Eyebrow label="Le fondateur" light />
        <h2 class="mt-6 display-xl !text-white" style="font-size:clamp(1.9rem,4vw,3rem)">
          Une histoire profondément <span class="text-terra-bright">humaine.</span>
        </h2>
        <p class="mt-6 text-white/75 leading-relaxed text-lg">
          L'histoire de Cœurs Braves est intimement liée au parcours de son fondateur,
          <strong class="text-white">{site.founder}</strong>. Comme beaucoup de jeunes Africains,
          il a connu les défis de l'entrepreneuriat, les périodes d'incertitude et les obstacles
          liés à la mobilité internationale.
        </p>
        <blockquote class="mt-6 border-l-2 border-terra-bright pl-5 text-white/90 italic">
          La réussite prend tout son sens lorsqu'elle devient un levier pour ouvrir des
          perspectives à d'autres.
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Valeurs -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24">
      <div class="text-center"><Eyebrow label="Nos valeurs" align="center" /></div>
      <h2 class="mt-6 section-title">Une communauté bâtie sur des <strong>valeurs.</strong></h2>
      <div class="mt-14 grid sm:grid-cols-3 gap-6">
        {valeurs.map((v) => (
          <div class="relative bg-cream rounded-2xl border border-hairline p-8 card-hover reveal overflow-hidden">
            <Motif name={v.motif} class="absolute -right-6 -top-6 w-28 h-28 text-ink/[0.04]" />
            <span class:list={["icon-chip w-14 h-14", v.chip]}><Motif name={v.motif} class="w-7 h-7" /></span>
            <h3 class="mt-6 font-display font-700 text-2xl" style="font-weight:700">{v.t}</h3>
            <p class="mt-3 text-ink-mute leading-relaxed">{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Frise chronologique -->
  <section class="bg-cream-2">
    <div class="container-cb py-20 md:py-24">
      <div class="text-center"><Eyebrow label="Notre parcours" align="center" /></div>
      <h2 class="mt-6 section-title">Les grandes <strong>étapes.</strong></h2>
      <div class="mt-16 relative max-w-3xl mx-auto">
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-hairline md:-translate-x-1/2"></div>
        <div class="space-y-8">
          {timeline.map((item, i) => (
            <div class="relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-10 reveal">
              <div class:list={["md:col-start-1", i % 2 === 0 ? "md:text-right md:pr-12" : "md:col-start-2 md:pl-12"]}>
                <div class="bg-cream border border-hairline rounded-xl p-6 shadow-sm text-left">
                  <span class="font-display font-700 text-sm text-terra" style="font-weight:700">Étape {String(i + 1).padStart(2, "0")}</span>
                  <h3 class="mt-1 font-display font-700 text-lg text-ink" style="font-weight:700">{item.t}</h3>
                  <p class="mt-2 text-sm text-ink-mute leading-relaxed">{item.d}</p>
                </div>
              </div>
              <span class="absolute left-4 md:left-1/2 top-2 w-4 h-4 rounded-full bg-terra ring-4 ring-cream-2 md:-translate-x-1/2"></span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Clôture -->
  <section class="bg-cream">
    <div class="container-cb py-20 text-center max-w-3xl">
      <Motif name="cross" class="w-10 h-10 mx-auto text-terra/40" />
      <p class="mt-6 font-display text-2xl md:text-3xl leading-snug text-ink" style="font-weight:600;letter-spacing:-0.02em">
        Si cette vision est aussi la vôtre, alors vous faites déjà partie de
        l'histoire de <span class="text-terra">Cœurs Braves.</span>
      </p>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <a href="/rejoindre/" class="btn btn-terra">Rejoindre la communauté</a>
        <a href="/ecosysteme/" class="btn btn-outline">Découvrir nos programmes</a>
      </div>
    </div>
  </section>
</Layout>
