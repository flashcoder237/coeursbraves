---
import Layout from "~/components/Layout.astro";
import PageHero from "~/components/PageHero.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import Motif from "~/components/Motif.astro";
import MotifTexture from "~/components/MotifTexture.astro";
import PatternBand from "~/components/PatternBand.astro";
import { site } from "~/data/site";
import { useTranslations, getLangFromUrl, localizePath } from "~/i18n/ui";
import { getHist } from "~/i18n/histoire";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);
const h = getHist(lang);

const valMeta = [
  { motif: "star", chip: "bg-terra/15 text-terra" },
  { motif: "cross", chip: "bg-emerald/15 text-emerald" },
  { motif: "zigzag", chip: "bg-gold/15 text-gold" },
];
---

<Layout title={h.hero.kicker} description={h.hero.subtitle}>
  <PageHero
    image="/images/cb/youth-laptop-2.jpg"
    kicker={h.hero.kicker}
    title={h.hero.title}
    subtitle={h.hero.subtitle}
  />

  <!-- Intro -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24 grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-7">
        <Eyebrow label={h.intro.eyebrow} />
        <h2 class="mt-6 section-title left">{h.intro.title} <strong>{h.intro.strong}</strong></h2>
      </div>
      <div class="lg:col-span-5 prose-cb reveal">
        <p>{h.intro.p1}</p>
        <p>{h.intro.p2}</p>
      </div>
    </div>
  </section>

  <PatternBand height={24} />

  <!-- Fondateur (vert forêt) -->
  <section class="relative bg-forest text-white overflow-hidden">
    <MotifTexture class="text-white/[0.06]" />
    <Motif name="eye" class="absolute -right-16 top-1/2 -translate-y-1/2 w-80 h-80 text-white/[0.05] hidden lg:block" />
    <div class="relative container-cb py-20 md:py-24 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <div class="rounded-[2rem] overflow-hidden ring-1 ring-white/10">
          <img src="/images/cb/entrepreneurs-meeting.jpg" alt="Transmission et accompagnement" class="w-full object-cover aspect-[4/3]" loading="lazy" />
        </div>
      </div>
      <div class="reveal">
        <Eyebrow label={h.founder.eyebrow} light />
        <h2 class="mt-6 display-xl !text-white" style="font-size:clamp(1.9rem,4vw,3rem)">
          {h.founder.title} <span class="text-terra-bright">{h.founder.accent}</span>
        </h2>
        <p class="mt-6 text-white/75 leading-relaxed text-lg">
          {h.founder.lead1} <strong class="text-white">{site.founder}</strong>{h.founder.lead2}
        </p>
        <blockquote class="mt-6 border-l-2 border-terra-bright pl-5 text-white/90 italic">
          {h.founder.quote}
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Valeurs -->
  <section class="bg-cream">
    <div class="container-cb py-20 md:py-24">
      <div class="text-center"><Eyebrow label={h.values.eyebrow} align="center" /></div>
      <h2 class="mt-6 section-title">{h.values.title} <strong>{h.values.strong}</strong></h2>
      <div class="mt-14 grid sm:grid-cols-3 gap-6">
        {h.values.items.map((v, i) => (
          <div class="relative bg-cream rounded-2xl border border-hairline p-8 card-hover reveal overflow-hidden">
            <Motif name={valMeta[i].motif} class="absolute -right-6 -top-6 w-28 h-28 text-ink/[0.04]" />
            <span class:list={["icon-chip w-14 h-14", valMeta[i].chip]}><Motif name={valMeta[i].motif} class="w-7 h-7" /></span>
            <h3 class="mt-6 font-display font-700 text-2xl" style="font-weight:700">{v.t}</h3>
            <p class="mt-3 text-ink-mute leading-relaxed">{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Frise chronologique -->
  <section class="bg-cream-2">
    <div class="container-cb py-20 md:py-24">
      <div class="text-center"><Eyebrow label={h.timeline.eyebrow} align="center" /></div>
      <h2 class="mt-6 section-title">{h.timeline.title} <strong>{h.timeline.strong}</strong></h2>
      <div class="mt-16 relative max-w-3xl mx-auto">
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-hairline md:-translate-x-1/2"></div>
        <div class="space-y-8">
          {h.timeline.items.map((item, i) => (
            <div class="relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-10 reveal">
              <div class:list={["md:col-start-1", i % 2 === 0 ? "md:text-right md:pr-12" : "md:col-start-2 md:pl-12"]}>
                <div class="bg-cream border border-hairline rounded-xl p-6 shadow-sm text-left">
                  <span class="font-display font-700 text-sm text-terra" style="font-weight:700">{h.timeline.label} {String(i + 1).padStart(2, "0")}</span>
                  <h3 class="mt-1 font-display font-700 text-lg text-ink" style="font-weight:700">{item.t}</h3>
                  <p class="mt-2 text-sm text-ink-mute leading-relaxed">{item.d}</p>
                </div>
              </div>
              <span class="absolute left-4 md:left-1/2 top-2 w-4 h-4 rounded-full bg-terra ring-4 ring-cream-2 md:-translate-x-1/2"></span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Clôture -->
  <section class="bg-cream">
    <div class="container-cb py-20 text-center max-w-3xl">
      <Motif name="cross" class="w-10 h-10 mx-auto text-terra/40" />
      <p class="mt-6 font-display text-2xl md:text-3xl leading-snug text-ink" style="font-weight:600;letter-spacing:-0.02em">
        {h.closing.text} <span class="text-terra">{h.closing.brand}</span>
      </p>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <a href={L("/rejoindre/")} class="btn btn-terra">{t("cta.join")}</a>
        <a href={L("/ecosysteme/")} class="btn btn-outline">{h.closing.cta2}</a>
      </div>
    </div>
  </section>
</Layout>
