---
import Layout from "~/components/Layout.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import Icon from "~/components/Icon.astro";
import MotifTexture from "~/components/MotifTexture.astro";
import PatternBand from "~/components/PatternBand.astro";
import { events } from "~/data/events";

const todayIso = new Date().toISOString().slice(0, 10);
const sorted = [...events].sort((a, b) => a.iso.localeCompare(b.iso));
const upcoming = sorted.filter((e) => e.iso >= todayIso);
const past = [...sorted.filter((e) => e.iso < todayIso)].reverse();

const dayNum = (iso: string) => iso.slice(8, 10);
const monthAbbr = (iso: string) => {
  const m = ["JAN", "FÉV", "MAR", "AVR", "MAI", "JUIN", "JUIL", "AOÛT", "SEP", "OCT", "NOV", "DÉC"];
  return m[parseInt(iso.slice(5, 7), 10) - 1];
};
const year = (iso: string) => iso.slice(0, 4);
---
<Layout
  title="Événements"
  description="L'agenda de Cœurs Braves : ateliers, webinaires, rencontres et forums au Cameroun, en Allemagne et en ligne."
>
  <!-- Hero « agenda » — signature or/ink -->
  <section class="relative bg-ink text-white overflow-hidden">
    <MotifTexture class="text-white/[0.05]" />
    <div class="absolute -right-24 -top-24 w-96 h-96 rounded-full bg-gold/10 blur-2xl"></div>
    <div class="relative container-cb pt-32 pb-20">
      <nav class="text-xs text-white/50 mb-6 flex items-center gap-2" aria-label="Fil d'ariane">
        <a href="/" class="hover:text-white transition-colors">Accueil</a><span>/</span><span class="text-white/80">Événements</span>
      </nav>
      <div class="grid lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-8">
          <span class="inline-flex items-center gap-2 text-gold font-bold text-xs uppercase tracking-[0.2em]">
            <Icon name="calendar" class="w-4 h-4" /> Agenda
          </span>
          <h1 class="mt-5 display-xl !text-white" style="font-size:clamp(2.4rem,5.5vw,4.4rem)">
            Nos prochains <span class="text-gold">rendez-vous.</span>
          </h1>
          <p class="mt-5 text-white/70 text-lg max-w-2xl leading-relaxed">
            Ateliers, webinaires, rencontres et forums : retrouvez la communauté Cœurs Braves,
            sur le terrain comme en ligne.
          </p>
        </div>
        <div class="lg:col-span-4 lg:text-right">
          <p class="font-display font-700 text-gold leading-none" style="font-weight:700;font-size:clamp(3rem,7vw,5rem)">{upcoming.length}</p>
          <p class="text-white/60 mt-2">événement{upcoming.length > 1 ? "s" : ""} à venir</p>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0"><PatternBand height={20} /></div>
  </section>

  <!-- Filtres -->
  <section class="bg-cream">
    <div class="container-cb pt-14">
      <div class="flex gap-2 border-b border-hairline" role="tablist">
        <button type="button" class="ev-tab is-active" data-tab="upcoming" role="tab">À venir ({upcoming.length})</button>
        <button type="button" class="ev-tab" data-tab="past" role="tab">Passés ({past.length})</button>
      </div>
    </div>
  </section>

  <!-- Liste À venir -->
  <section class="bg-cream" id="ev-upcoming">
    <div class="container-cb py-12 md:py-16">
      {upcoming.length === 0 && (
        <p class="text-ink-mute py-8">Aucun événement programmé pour l'instant — revenez bientôt&nbsp;!</p>
      )}
      <div class="space-y-5">
        {upcoming.map((e) => (
          <article class="ev-row reveal group">
            <div class="ev-date">
              <span class="ev-day">{dayNum(e.iso)}</span>
              <span class="ev-month">{monthAbbr(e.iso)}</span>
              <span class="ev-year">{year(e.iso)}</span>
            </div>
            <div class="ev-media">
              <img src={e.image} alt={e.title} width="400" height="300" loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            </div>
            <div class="ev-body">
              <div class="flex flex-wrap items-center gap-2.5 mb-2">
                <span class="ev-type">{e.type}</span>
                <span class:list={["ev-mode", e.online ? "ev-mode-online" : "ev-mode-place"]}>
                  <Icon name={e.online ? "globe" : "map-pin"} class="w-3.5 h-3.5" /> {e.online ? "En ligne" : e.city}
                </span>
              </div>
              <h2 class="font-display font-700 text-xl leading-snug" style="font-weight:700">{e.title}</h2>
              <p class="mt-2 text-ink-soft text-sm leading-relaxed">{e.excerpt}</p>
              <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink-mute">
                <span class="inline-flex items-center gap-1.5"><Icon name="clock" class="w-4 h-4 text-gold" /> {e.time}</span>
                <span class="inline-flex items-center gap-1.5"><Icon name="map-pin" class="w-4 h-4 text-gold" /> {e.place}</span>
              </div>
            </div>
            <div class="ev-cta">
              <a href={e.registerUrl} class="btn btn-gold text-sm"><Icon name="ticket" class="w-4 h-4" /> S'inscrire</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Liste Passés -->
  <section class="bg-cream hidden" id="ev-past">
    <div class="container-cb py-12 md:py-16">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {past.map((e) => (
          <article class="reveal bg-cream-2 border border-hairline rounded-2xl overflow-hidden opacity-90">
            <div class="relative aspect-[16/10] overflow-hidden">
              <img src={e.image} alt={e.title} width="400" height="250" loading="lazy" class="w-full h-full object-cover grayscale-[35%]" />
              <span class="ev-type absolute top-3 left-3">{e.type}</span>
            </div>
            <div class="p-5">
              <p class="text-xs text-ink-mute">{e.dateLabel} · {e.city}</p>
              <h2 class="font-display font-700 text-base leading-snug mt-1" style="font-weight:700">{e.title}</h2>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <PatternBand height={22} />

  <!-- CTA -->
  <section class="bg-cream-2">
    <div class="container-cb py-16 text-center max-w-xl">
      <Eyebrow label="Ne rien manquer" align="center" />
      <h2 class="mt-5 section-title" style="font-size:clamp(1.6rem,3vw,2.3rem)">Recevez nos prochains <strong>rendez-vous.</strong></h2>
      <a href="/#newsletter" class="btn btn-terra mt-6">S'abonner à la newsletter</a>
    </div>
  </section>

  <script is:inline>
    (function () {
      var tabs = document.querySelectorAll(".ev-tab");
      var up = document.getElementById("ev-upcoming");
      var past = document.getElementById("ev-past");
      if (!tabs.length || !up || !past) return;
      tabs.forEach(function (t) {
        t.addEventListener("click", function () {
          tabs.forEach(function (x) { x.classList.toggle("is-active", x === t); });
          var isPast = t.dataset.tab === "past";
          past.classList.toggle("hidden", !isPast);
          up.classList.toggle("hidden", isPast);
        });
      });
    })();
  </script>
</Layout>
