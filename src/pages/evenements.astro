---
import Layout from "~/components/Layout.astro";
import Eyebrow from "~/components/Eyebrow.astro";
import Icon from "~/components/Icon.astro";
import MotifTexture from "~/components/MotifTexture.astro";
import PatternBand from "~/components/PatternBand.astro";
import { useTranslations, getLangFromUrl, localizePath } from "~/i18n/ui";
import { getEvents } from "~/i18n/content";
import { site } from "~/data/site";
import ShareButtons from "~/components/ShareButtons.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);

// Lien d'inscription : le vrai lien s'il existe, sinon un e-mail pré-rempli
// (inscription par mail, sans back-end) plutôt qu'un « # » qui ne mène nulle part.
const regHref = (url: string | undefined, title: string) =>
  url && url !== "#"
    ? url
    : `mailto:${site.email}?subject=${encodeURIComponent(`${t("events.register")} — ${title}`)}`;

const todayIso = new Date().toISOString().slice(0, 10);
const all = await getEvents(lang);
const upcoming = all.filter((e) => e.data.iso >= todayIso);
const past = [...all.filter((e) => e.data.iso < todayIso)].reverse();

const d = (iso: string) => new Date(iso + "T00:00:00Z");
const dayNum = (iso: string) => String(d(iso).getUTCDate()).padStart(2, "0");
const monthAbbr = (iso: string) =>
  new Intl.DateTimeFormat(lang, { month: "short", timeZone: "UTC" }).format(d(iso)).replace(".", "").toUpperCase();
const yearNum = (iso: string) => iso.slice(0, 4);
const dateLabel = (iso: string) =>
  new Intl.DateTimeFormat(lang, { day: "numeric", month: "long", year: "numeric", timeZone: "UTC" }).format(d(iso));

// Galerie « en images » — photos réelles de la communauté (page Facebook)
const gallery = [
  { src: "/images/cb/events/diner.jpg", alt: "La Marmite des Cœurs Braves, Sangmélima" },
  { src: "/images/cb/events/rassemblement.jpg", alt: "Rassemblement de la communauté Cœurs Braves" },
  { src: "/images/cb/events/celebration.jpg", alt: "Célébration au sein de la communauté" },
  { src: "/images/cb/events/supporters.jpg", alt: "Soirée communautaire à La Marmite" },
  { src: "/images/cb/events/soiree.jpg", alt: "Soirée lounge à La Marmite des Cœurs Braves" },
  { src: "/images/cb/events/ambiance.jpg", alt: "Ambiance d'une rencontre Cœurs Braves" },
  { src: "/images/cb/events/supporters-2.jpg", alt: "Supporters réunis à La Marmite" },
];
---
<Layout title={t("nav.events")} description={t("events.subtitle")} image="/images/cb/events/rassemblement.jpg">
  <!-- Hero « agenda » — signature or/ink -->
  <section class="relative bg-ink text-white overflow-hidden">
    <MotifTexture class="text-white/[0.05]" />
    <div class="absolute -right-24 -top-24 w-96 h-96 rounded-full bg-gold/10 blur-2xl"></div>
    <div class="relative container-cb pt-32 pb-20">
      <nav class="text-xs text-white/50 mb-6 flex items-center gap-2" aria-label="Fil d'ariane">
        <a href={L("/")} class="hover:text-white transition-colors">{t("nav.home")}</a><span>/</span><span class="text-white/80">{t("nav.events")}</span>
      </nav>
      <div class="grid lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-8">
          <span class="inline-flex items-center gap-2 text-gold font-bold text-xs uppercase tracking-[0.2em]">
            <Icon name="calendar" class="w-4 h-4" /> {t("events.kicker")}
          </span>
          <h1 class="mt-5 display-xl !text-white" style="font-size:clamp(2.4rem,5.5vw,4.4rem)">
            {t("events.title")} <span class="text-gold">{t("events.title_accent")}</span>
          </h1>
          <p class="mt-5 text-white/70 text-lg max-w-2xl leading-relaxed">{t("events.subtitle")}</p>
        </div>
        <div class="lg:col-span-4 lg:text-right">
          <p class="font-display font-700 text-gold leading-none" style="font-weight:700;font-size:clamp(3rem,7vw,5rem)">{upcoming.length}</p>
          <p class="text-white/60 mt-2">{t("events.upcoming_count")}</p>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0"><PatternBand height={20} /></div>
  </section>

  <!-- Filtres -->
  <section class="bg-cream">
    <div class="container-cb pt-14">
      <div class="flex gap-2 border-b border-hairline" role="tablist">
        <button type="button" class="ev-tab is-active" data-tab="upcoming" role="tab">{t("events.tab_upcoming")} ({upcoming.length})</button>
        <button type="button" class="ev-tab" data-tab="past" role="tab">{t("events.tab_past")} ({past.length})</button>
      </div>
    </div>
  </section>

  <!-- Liste À venir -->
  <section class="bg-cream" id="ev-upcoming">
    <div class="container-cb py-12 md:py-16">
      {upcoming.length === 0 && (<p class="text-ink-mute py-8">{t("events.none")}</p>)}
      <div class="space-y-5">
        {upcoming.map((e) => (
          <article class="ev-row reveal group">
            <div class="ev-date">
              <span class="ev-day">{dayNum(e.data.iso)}</span>
              <span class="ev-month">{monthAbbr(e.data.iso)}</span>
              <span class="ev-year">{yearNum(e.data.iso)}</span>
            </div>
            <div class="ev-media">
              <img src={e.data.image} alt={e.data.title} width="400" height="300" loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            </div>
            <div class="ev-body">
              <div class="flex flex-wrap items-center gap-2.5 mb-2">
                <span class="ev-type">{e.data.type}</span>
                <span class:list={["ev-mode", e.data.online ? "ev-mode-online" : "ev-mode-place"]}>
                  <Icon name={e.data.online ? "globe" : "map-pin"} class="w-3.5 h-3.5" /> {e.data.online ? t("events.online") : e.data.city}
                </span>
              </div>
              <h2 class="font-display font-700 text-xl leading-snug" style="font-weight:700">{e.data.title}</h2>
              <p class="mt-2 text-ink-soft text-sm leading-relaxed">{e.data.excerpt}</p>
              <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink-mute">
                <span class="inline-flex items-center gap-1.5"><Icon name="clock" class="w-4 h-4 text-gold" /> {e.data.time}</span>
                <span class="inline-flex items-center gap-1.5"><Icon name="map-pin" class="w-4 h-4 text-gold" /> {e.data.place}</span>
              </div>
            </div>
            <div class="ev-cta">
              <a href={regHref(e.data.registerUrl, e.data.title)} class="btn btn-gold text-sm"><Icon name="ticket" class="w-4 h-4" /> {t("events.register")}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Liste Passés -->
  <section class="bg-cream hidden" id="ev-past">
    <div class="container-cb py-12 md:py-16">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {past.map((e) => (
          <article class="reveal bg-cream-2 border border-hairline rounded-2xl overflow-hidden opacity-90">
            <div class="relative aspect-[16/10] overflow-hidden">
              <img src={e.data.image} alt={e.data.title} width="400" height="250" loading="lazy" class="w-full h-full object-cover grayscale-[35%]" />
              <span class="ev-type absolute top-3 left-3">{e.data.type}</span>
            </div>
            <div class="p-5">
              <p class="text-xs text-ink-mute">{dateLabel(e.data.iso)} · {e.data.city}</p>
              <h2 class="font-display font-700 text-base leading-snug mt-1" style="font-weight:700">{e.data.title}</h2>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Cœurs Braves en images -->
  <section class="relative bg-ink text-white overflow-hidden">
    <MotifTexture class="text-white/[0.05]" />
    <div class="relative container-cb py-20 md:py-24">
      <div class="max-w-2xl">
        <Eyebrow label={t("events.gallery_kicker")} light />
        <h2 class="mt-6 display-xl !text-white" style="font-size:clamp(1.9rem,4vw,3rem)">
          {t("events.gallery_title")} <span class="text-gold">{t("events.gallery_accent")}</span>
        </h2>
        <p class="mt-5 text-white/60 text-lg leading-relaxed">{t("events.gallery_text")}</p>
      </div>
      <div class="mt-12 columns-2 sm:columns-3 lg:columns-4 gap-4">
        {gallery.map((g) => (
          <img src={g.src} alt={g.alt} loading="lazy"
            class="mb-4 w-full rounded-xl break-inside-avoid border border-white/10 hover:opacity-90 transition-opacity" />
        ))}
      </div>
      <p class="mt-6 text-xs text-white/40">Photos : page Facebook Cœurs Braves.</p>
    </div>
  </section>

  <PatternBand height={22} />

  <!-- CTA -->
  <section class="bg-cream-2">
    <div class="container-cb py-16 text-center max-w-xl">
      <Eyebrow label={t("events.nl_kicker")} align="center" />
      <h2 class="mt-5 section-title" style="font-size:clamp(1.6rem,3vw,2.3rem)">{t("events.nl_title")}</h2>
      <a href={L("/journal/") + "#newsletter"} class="btn btn-terra mt-6">{t("newsletter.subscribe")}</a>
      <div class="mt-10 pt-8 border-t border-hairline flex justify-center">
        <ShareButtons
          url={new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href}
          title={t("nav.events") + " — " + site.name}
          label={lang === "en" ? "Share" : lang === "de" ? "Teilen" : "Partager l'agenda"}
        />
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var tabs = document.querySelectorAll(".ev-tab");
      var up = document.getElementById("ev-upcoming");
      var past = document.getElementById("ev-past");
      if (!tabs.length || !up || !past) return;
      tabs.forEach(function (t) {
        t.addEventListener("click", function () {
          tabs.forEach(function (x) { x.classList.toggle("is-active", x === t); });
          var isPast = t.dataset.tab === "past";
          past.classList.toggle("hidden", !isPast);
          up.classList.toggle("hidden", isPast);
        });
      });
    })();
  </script>
</Layout>
