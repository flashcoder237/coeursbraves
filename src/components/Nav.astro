---
import { nav } from "~/data/site";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header id="cb-header" class="sticky top-0 z-50 bg-cream/85 backdrop-blur-md transition-all">
  <div class="container-cb flex items-center justify-between gap-4 h-[76px]">
    <!-- Logo -->
    <a href="/" class="flex items-center shrink-0 cb-logo-link" aria-label="Cœurs Braves — accueil">
      <img src="/images/cb/logo.png" alt="Cœurs Braves" width="280" height="120"
           class="h-8 md:h-9 w-auto" />
    </a>

    <!-- Navigation desktop -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Navigation principale">
      {nav.filter((n) => n.href !== "/").map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-[0.95rem] font-medium transition-colors",
            isActive(item.href) ? "text-terra" : "text-ink-soft hover:text-terra",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href="/soutenir/" class="btn btn-dark text-sm px-6 py-3 hidden sm:inline-flex">Soutenir nos actions</a>
      <button id="cb-burger" class="lg:hidden p-2 text-ink" aria-label="Ouvrir le menu" aria-expanded="false">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menu mobile -->
  <div id="cb-mobile" class="lg:hidden hidden border-t border-hairline bg-cream">
    <nav class="container-cb flex flex-col py-3" aria-label="Navigation mobile">
      {nav.filter((n) => n.href !== "/").map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-base font-medium py-3 border-b border-hairline/60",
            isActive(item.href) ? "text-terra" : "text-ink",
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href="/soutenir/" class="btn btn-dark mt-4">Soutenir nos actions</a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const burger = document.getElementById("cb-burger");
    const menu = document.getElementById("cb-mobile");
    const header = document.getElementById("cb-header");
    if (burger && menu) {
      burger.addEventListener("click", () => {
        const open = menu.classList.toggle("hidden");
        burger.setAttribute("aria-expanded", String(open ? false : true));
      });
    }
    if (header) {
      const onScroll = () => {
        if (window.scrollY > 8) header.classList.add("shadow-sm", "border-b", "border-hairline");
        else header.classList.remove("shadow-sm", "border-b", "border-hairline");
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    }
  })();
</script>
