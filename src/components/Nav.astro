---
import Icon from "./Icon.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { navGroups, navSingles, useTranslations, getLangFromUrl, localizePath } from "~/i18n/ui";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const path = Astro.url.pathname;
const home = localizePath("/", lang);
const isActive = (href: string) => {
  const full = localizePath(href, lang);
  return path === full || path.startsWith(full);
};
const groupActive = (items: readonly { href: string }[]) => items.some((it) => isActive(it.href));
---

<header id="cb-header" class="sticky top-0 z-50 bg-cream/85 backdrop-blur-md transition-all">
  <div class="container-cb flex items-center justify-between gap-4 h-[76px]">
    <!-- Logo -->
    <a href={home} class="flex items-center shrink-0 cb-logo-link" aria-label="Cœurs Braves — accueil">
      <img src="/images/cb/logo.png" alt="Cœurs Braves" width="280" height="120"
           class="h-8 md:h-9 w-auto" />
    </a>

    <!-- Navigation desktop -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Navigation principale">
      {navGroups.map((group) => (
        <div class="nav-group">
          <button type="button" class:list={["nav-group-btn", groupActive(group.items) && "is-active"]} aria-haspopup="true" aria-expanded="false">
            {t(group.key)}
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="nav-dropdown">
            {group.items.map((it) => (
              <a href={localizePath(it.href, lang)} class:list={["nav-dropdown-item", isActive(it.href) && "is-active"]}>{t(it.key)}</a>
            ))}
          </div>
        </div>
      ))}
      {navSingles.map((it) => (
        <a href={localizePath(it.href, lang)}
          class:list={["nav-link nav-single text-[0.95rem] font-medium transition-colors", isActive(it.href) ? "is-active" : "text-ink-soft hover:text-terra"]}>
          {t(it.key)}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-1.5">
      <LanguageSwitcher />
      <button type="button" id="cb-search-open" class="search-trigger" aria-label={t("a11y.search")}>
        <Icon name="search" class="w-5 h-5" />
      </button>
      <a href={localizePath("/soutenir/", lang)} class="btn btn-dark text-sm px-6 py-3 hidden sm:inline-flex">{t("cta.support")}</a>
      <button id="cb-burger" class="lg:hidden p-2 text-ink" aria-label={t("a11y.menu")} aria-expanded="false">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menu mobile -->
  <div id="cb-mobile" class="lg:hidden hidden border-t border-hairline bg-cream">
    <nav class="container-cb flex flex-col py-3" aria-label="Navigation mobile">
      {navGroups.map((group) => (
        <div class="py-2 border-b border-hairline/60">
          <p class="nav-mobile-group">{t(group.key)}</p>
          {group.items.map((it) => (
            <a href={localizePath(it.href, lang)}
              class:list={["block py-2.5 pl-3 text-base", isActive(it.href) ? "text-terra font-medium" : "text-ink"]}>
              {t(it.key)}
            </a>
          ))}
        </div>
      ))}
      {navSingles.map((it) => (
        <a href={localizePath(it.href, lang)}
          class:list={["py-3 text-base font-medium border-b border-hairline/60", isActive(it.href) ? "text-terra" : "text-ink"]}>
          {t(it.key)}
        </a>
      ))}
      <a href={localizePath("/soutenir/", lang)} class="btn btn-dark mt-4">{t("cta.support")}</a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const burger = document.getElementById("cb-burger");
    const menu = document.getElementById("cb-mobile");
    const header = document.getElementById("cb-header");
    if (burger && menu) {
      burger.addEventListener("click", () => {
        const open = menu.classList.toggle("hidden");
        burger.setAttribute("aria-expanded", String(open ? false : true));
      });
    }
    // Menus déroulants : clic/tactile (le survol est géré en CSS).
    const groups = document.querySelectorAll(".nav-group");
    groups.forEach((g) => {
      const btn = g.querySelector(".nav-group-btn");
      if (!btn) return;
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const open = g.classList.contains("is-open");
        groups.forEach((x) => { x.classList.remove("is-open"); x.querySelector(".nav-group-btn").setAttribute("aria-expanded", "false"); });
        if (!open) { g.classList.add("is-open"); btn.setAttribute("aria-expanded", "true"); }
      });
    });
    document.addEventListener("click", () => {
      groups.forEach((x) => { x.classList.remove("is-open"); x.querySelector(".nav-group-btn").setAttribute("aria-expanded", "false"); });
    });
    if (header) {
      const onScroll = () => {
        if (window.scrollY > 8) header.classList.add("shadow-sm", "border-b", "border-hairline");
        else header.classList.remove("shadow-sm", "border-b", "border-hairline");
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    }
  })();
</script>
