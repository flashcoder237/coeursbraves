---
import { getStrings, type Locale } from "~/i18n/strings";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);
---

<section id="manifesto" class="py-32 px-4 md:px-8 reveal">
  <div class="max-w-[1100px] mx-auto flex flex-col md:flex-row gap-8 md:gap-16 items-start">
    <div class="md:w-1/4 pt-2">
      <span class="font-mono text-xs uppercase tracking-widest text-ink-soft block">
        <span class="block w-12 border-t border-ink-soft/40 pt-2">{t.manifesto.label}</span>
      </span>
    </div>
    <div class="md:w-3/4">
      <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.1] tracking-tightest text-balance">
        {t.manifesto.quote}
        <span class="text-accent-ochre inline-block relative">
          {t.manifesto.quoteHighlight}
          <svg
            class="absolute bottom-0 left-0 w-full text-accent-ochre/40 -mb-2"
            viewBox="0 0 100 10"
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            <path d="M0,5 C30,10 70,0 100,5" stroke="currentColor" stroke-width="2" fill="none" />
          </svg>
        </span>
        {t.manifesto.quoteSuffix}
      </h2>
      <div class="mt-12 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full overflow-hidden border-hairline">
          <img
            src="https://images.unsplash.com/photo-1531384441138-2736e62e0919?auto=format&fit=crop&w=150&q=80"
            alt="Portrait du conseil d’administration"
            class="w-full h-full object-cover grayscale"
            loading="lazy"
          />
        </div>
        <div>
          <p class="font-medium text-sm">{t.manifesto.attributionTitle}</p>
          <p class="text-xs font-mono text-ink-soft">{t.manifesto.attributionLocation}</p>
        </div>
      </div>
    </div>
  </div>
</section>
