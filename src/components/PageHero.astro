---
import PatternBand from "./PatternBand.astro";
import MotifTexture from "./MotifTexture.astro";
interface Props {
  image: string;
  kicker?: string;
  title: string;
  subtitle?: string;
  height?: string;
}
const { image, kicker, title, subtitle, height = "min-h-[54vh]" } = Astro.props;
---

<section class={`relative flex items-end ${height} overflow-hidden`}>
  <img src={image} alt="" class="absolute inset-0 w-full h-full object-cover" />
  <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/70 to-forest/25"></div>
  <MotifTexture class="text-white/[0.07]" />
  <div class="relative container-cb pb-16 pt-36 text-white">
    {kicker && <span class="badge badge-light mb-5">{kicker}</span>}
    <h1 class="display-xl !text-white max-w-4xl" style="font-size:clamp(2.4rem,5.5vw,4.4rem)">{title}</h1>
    {subtitle && <p class="mt-5 text-white/85 text-lg max-w-2xl leading-relaxed">{subtitle}</p>}
  </div>
  <div class="absolute bottom-0 left-0 right-0"><PatternBand height={22} /></div>
</section>
