---
import { getStrings, type Locale } from "~/i18n/strings";
import { poleUrl, localePath } from "~/lib/urls";
import { loadPage } from "~/lib/pages";

interface Props {
  locale: Locale;
  poleLinks: { nom: string; slug: string }[];
}

const { locale, poleLinks } = Astro.props;
const t = getStrings(locale);

const contactPage = await loadPage("contact", locale);
const contactAudiences = contactPage?.data.contact?.audiences ?? [];

const langs: { code: Locale; label: string; href: string }[] = [
  { code: "fr", label: "FR", href: localePath("/", "fr") },
  { code: "de", label: "DE", href: localePath("/", "de") },
  { code: "en", label: "EN", href: localePath("/", "en") },
];

const homeHref = localePath("/", locale);
const contactHref = localePath("/contact", locale);
---

<footer class="bg-[#171715] text-paper rounded-t-[2rem] md:rounded-t-[3rem] mt-12 pt-20 pb-8 px-4 md:px-8 relative z-10">
  <div class="max-w-[1400px] mx-auto">

    <!-- Top CTA strip + newsletter -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20">
      <div class="lg:col-span-6">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tightest mb-4 text-balance">{t.footer.ctaTitle}</h2>
        <p class="text-white/60 font-light text-lg max-w-md">{t.footer.ctaIntro}</p>

        <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl">
          <a
            href="mailto:bonjour@coeurs-braves.com"
            class="group flex items-center justify-between bg-white/5 border border-white/10 p-4 rounded-xl hover:bg-white/10 transition-colors"
          >
            <div>
              <span class="block text-xs text-white/50 mb-1 font-mono uppercase tracking-widest">{t.footer.mailLabel}</span>
              <span class="text-base font-medium">bonjour@coeurs-braves.com</span>
            </div>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-white/50 group-hover:text-white transition-colors">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="9 7 17 7 17 15"></polyline>
            </svg>
          </a>
          <a
            href={contactHref}
            class="group flex items-center justify-between bg-white/5 border border-white/10 p-4 rounded-xl hover:bg-accent-ochre transition-colors"
          >
            <div>
              <span class="block text-xs text-white/50 group-hover:text-ink/60 mb-1 font-mono uppercase tracking-widest transition-colors">{t.footer.investLabel}</span>
              <span class="text-base font-medium group-hover:text-ink transition-colors">{t.footer.investAction}</span>
            </div>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-white/50 group-hover:text-ink transition-colors">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="9 7 17 7 17 15"></polyline>
            </svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-6 lg:col-start-7 bg-white/[0.04] border border-white/10 rounded-2xl p-6 md:p-8 flex flex-col">
        <span class="font-mono text-[10px] uppercase tracking-widest text-white/40 mb-3">{t.footer.newsletterTitle}</span>
        <p class="text-white/80 leading-relaxed mb-6">{t.footer.newsletterIntro}</p>
        <form class="flex items-center gap-2 border-b border-white/20 focus-within:border-accent-ochre transition-colors pb-2" action="#" method="post">
          <input
            type="email"
            name="email"
            required
            placeholder={t.footer.newsletterPlaceholder}
            class="flex-1 bg-transparent outline-none placeholder-white/30 text-white font-mono text-sm py-2"
          />
          <button
            type="submit"
            class="font-mono text-[11px] uppercase tracking-widest text-white hover:text-accent-ochre transition-colors px-3 py-2"
          >
            {t.footer.newsletterSubmit} →
          </button>
        </form>
      </div>
    </div>

    <!-- 6-column secondary nav -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 py-12 border-t border-white/10 border-b">

      <div class="flex flex-col gap-3">
        <span class="font-mono text-xs text-white/40 mb-2 uppercase tracking-widest">{t.footer.columns.worlds}</span>
        {poleLinks.map((p) => (
          <a href={poleUrl(p.slug, locale)} class="text-sm font-medium hover:text-accent-ochre transition-colors">{p.nom}</a>
        ))}
      </div>

      <div class="flex flex-col gap-3">
        <span class="font-mono text-xs text-white/40 mb-2 uppercase tracking-widest">{t.footer.columns.initiative}</span>
        <a href={`${homeHref}#manifesto`} class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.initiative.manifesto}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.initiative.council}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.initiative.history}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.initiative.careers}</a>
      </div>

      <div class="flex flex-col gap-3">
        <span class="font-mono text-xs text-white/40 mb-2 uppercase tracking-widest">{t.footer.columns.resources}</span>
        <a href={`${homeHref}#journal`} class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.resources.journal}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.resources.press}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.resources.reports}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.resources.faq}</a>
      </div>

      <div class="flex flex-col gap-3">
        <span class="font-mono text-xs text-white/40 mb-2 uppercase tracking-widest">{t.footer.columns.programmes}</span>
        <a href={`${homeHref}#raffinerie`} class="text-sm font-medium hover:text-accent-ochre transition-colors">{t.footer.programmes.raffinerie}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.programmes.candidates}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.programmes.investors}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.programmes.diaspora}</a>
      </div>

      <div class="flex flex-col gap-3">
        <span class="font-mono text-xs text-white/40 mb-2 uppercase tracking-widest">{t.footer.columns.contact}</span>
        {contactAudiences.map((a) => (
          <a href={contactHref} class="text-sm font-medium hover:text-white/70 transition-colors">{a.title}</a>
        ))}
        <a href="mailto:bonjour@coeurs-braves.com" class="text-sm font-mono text-white/40 hover:text-white transition-colors mt-2">bonjour@coeurs-braves.com</a>
      </div>

      <div class="flex flex-col gap-3">
        <span class="font-mono text-xs text-white/40 mb-2 uppercase tracking-widest">{t.footer.columns.legal}</span>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.legal.mentions}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.legal.privacy}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.legal.terms}</a>
        <a href="#" class="text-sm font-medium hover:text-white/70 transition-colors">{t.footer.legal.cookies}</a>
      </div>
    </div>

    <!-- Lang switch + social -->
    <div class="py-10 flex flex-col md:flex-row md:justify-between gap-6 border-b border-white/10">
      <div class="flex items-center gap-6">
        <span class="font-mono text-[10px] uppercase tracking-widest text-white/40">Language</span>
        <div class="flex gap-3 font-medium text-sm">
          {langs.map((l) => (
            <a
              href={l.href}
              class:list={["transition-colors", l.code === locale ? "text-white" : "text-white/40 hover:text-white"]}
              aria-current={l.code === locale ? "true" : undefined}
            >
              {l.label}
            </a>
          ))}
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span class="font-mono text-[10px] uppercase tracking-widest text-white/40 mr-2">{t.contact.socialTitle}</span>
        <a href="#" aria-label="LinkedIn" class="w-8 h-8 rounded-full border border-white/15 flex items-center justify-center text-white/70 hover:text-white hover:border-white transition-colors">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><line x1="8" y1="11" x2="8" y2="17"/><circle cx="8" cy="7.5" r="0.5" fill="currentColor"/><path d="M12 17v-3a2 2 0 1 1 4 0v3"/><line x1="12" y1="11" x2="12" y2="17"/></svg>
        </a>
        <a href="#" aria-label="X" class="w-8 h-8 rounded-full border border-white/15 flex items-center justify-center text-white/70 hover:text-white hover:border-white transition-colors">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
        </a>
        <a href="#" aria-label="Instagram" class="w-8 h-8 rounded-full border border-white/15 flex items-center justify-center text-white/70 hover:text-white hover:border-white transition-colors">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
        </a>
        <a href="#" aria-label="YouTube" class="w-8 h-8 rounded-full border border-white/15 flex items-center justify-center text-white/70 hover:text-white hover:border-white transition-colors">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="3"/><polygon points="10 9 16 12 10 15 10 9" fill="currentColor"/></svg>
        </a>
      </div>
    </div>

    <!-- Wordmark masthead -->
    <div class="mt-12 overflow-hidden flex justify-center w-full">
      <h2 class="text-[14vw] leading-[0.75] font-bold tracking-tighter text-white/90 text-center uppercase pointer-events-none select-none">
        Cœurs Braves
      </h2>
    </div>

    <div class="mt-6 flex flex-col md:flex-row justify-between gap-2 text-[10px] font-mono text-white/30 uppercase tracking-widest">
      <p>{t.footer.rights}</p>
      <p>{t.footer.tagline}</p>
    </div>
  </div>
</footer>
