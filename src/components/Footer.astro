---
import { site, nav } from "~/data/site";
import Icon from "./Icon.astro";
import PatternBand from "./PatternBand.astro";
import MotifTexture from "./MotifTexture.astro";
const year = new Date().getFullYear();
---

<!-- Bande d'appel — terracotta -->
<section class="bg-cream">
  <div class="container-cb pb-20">
    <div class="relative overflow-hidden rounded-[2rem] bg-terra text-white px-8 md:px-16 py-16 md:py-20 text-center">
      <MotifTexture class="text-white/[0.09]" />
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full bg-white/10"></div>
      <div class="absolute -bottom-20 -left-10 w-56 h-56 rounded-full bg-white/5"></div>
      <div class="relative">
        <h2 class="display-xl !text-white mx-auto max-w-3xl" style="font-size:clamp(2rem,4.5vw,3.4rem)">
          Les grandes transformations commencent par une décision.
        </h2>
        <p class="mt-5 text-white/85 max-w-2xl mx-auto text-lg">
          Que vous souhaitiez apprendre, entreprendre, investir ou soutenir une initiative,
          votre engagement peut faire la différence.
        </p>
        <div class="mt-9 flex flex-wrap gap-3 justify-center">
          <a href="/rejoindre/" class="btn btn-cream">Rejoindre la communauté</a>
          <a href="/soutenir/" class="btn btn-ghost-white">Soutenir nos actions</a>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="bg-forest text-white/65">
  <PatternBand height={26} />
  <div class="container-cb py-16 grid gap-10 md:grid-cols-12">
    <div class="md:col-span-4">
      <div class="flex items-center">
        <img src="/images/cb/logo.png" alt="Cœurs Braves" width="280" height="120"
             class="h-9 w-auto" style="filter: brightness(0) invert(1);" />
      </div>
      <p class="mt-5 text-sm leading-relaxed max-w-xs">
        Association internationale africaine qui investit dans l'humain pour créer
        des opportunités durables.
      </p>
      <a href="/contact/" class="btn btn-terra mt-6 text-sm">Contactez-nous</a>
    </div>

    <div class="md:col-span-3">
      <h3 class="font-display font-semibold text-white text-xs uppercase tracking-[0.18em] mb-4">Navigation</h3>
      <ul class="space-y-2.5 text-sm">
        {nav.map((n) => (
          <li><a href={n.href} class="hover:text-white transition">{n.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-3">
      <h3 class="font-display font-semibold text-white text-xs uppercase tracking-[0.18em] mb-4">S'engager</h3>
      <ul class="space-y-2.5 text-sm">
        <li><a href="/rejoindre/" class="hover:text-white transition">Devenir membre</a></li>
        <li><a href="/rejoindre/" class="hover:text-white transition">Devenir bénévole</a></li>
        <li><a href="/partenaires/" class="hover:text-white transition">Devenir partenaire</a></li>
        <li><a href="/soutenir/" class="hover:text-white transition">Faire un don</a></li>
      </ul>
    </div>

    <div class="md:col-span-2">
      <h3 class="font-display font-semibold text-white text-xs uppercase tracking-[0.18em] mb-4">Présence</h3>
      <ul class="space-y-2.5 text-sm">
        {site.countries.map((c) => <li>{c}</li>)}
      </ul>
      <a href={site.social.facebook} target="_blank" rel="noopener" class="inline-flex items-center gap-2 mt-4 text-sm hover:text-white transition">
        <Icon name="facebook" class="w-4 h-4" /> Facebook
      </a>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-cb py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/50">
      <p>© {year} {site.legalName}. Tous droits réservés.</p>
      <p>Investir dans l'humain, c'est construire l'avenir.</p>
    </div>
  </div>
</footer>
