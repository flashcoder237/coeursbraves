---
import { site } from "~/data/site";
import Icon from "./Icon.astro";
import PatternBand from "./PatternBand.astro";
import MotifTexture from "./MotifTexture.astro";
import { navItems, useTranslations, getLangFromUrl, localizePath, countries } from "~/i18n/ui";
const year = new Date().getFullYear();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);
---

<!-- Bande d'appel — terracotta -->
<section class="bg-cream mt-20">
  <div class="container-cb pb-20">
    <div class="relative overflow-hidden rounded-[2rem] bg-terra text-white px-8 md:px-16 py-16 md:py-20 text-center">
      <MotifTexture class="text-white/[0.09]" />
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full bg-white/10"></div>
      <div class="absolute -bottom-20 -left-10 w-56 h-56 rounded-full bg-white/5"></div>
      <div class="relative">
        <h2 class="display-xl !text-white mx-auto max-w-3xl" style="font-size:clamp(2rem,4.5vw,3.4rem)">
          {t("footer.cta_title")}
        </h2>
        <p class="mt-5 text-white/85 max-w-2xl mx-auto text-lg">
          {t("footer.cta_text")}
        </p>
        <div class="mt-9 flex flex-wrap gap-3 justify-center">
          <a href={L("/rejoindre/")} class="btn btn-cream">{t("cta.join")}</a>
          <a href={L("/soutenir/")} class="btn btn-ghost-white">{t("cta.support")}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="bg-forest text-white/65">
  <PatternBand height={26} />
  <div class="container-cb py-16 grid gap-10 md:grid-cols-12">
    <div class="md:col-span-4">
      <div class="flex items-center">
        <img src="/images/cb/logo.png" alt="Cœurs Braves" width="280" height="120"
             class="h-9 w-auto" style="filter: brightness(0) invert(1);" />
      </div>
      <p class="mt-5 text-sm leading-relaxed max-w-xs">
        {t("footer.tagline")}
      </p>
      <ul class="mt-6 space-y-2.5 text-sm">
        <li>
          <a href={`mailto:${site.email}`} class="inline-flex items-center gap-2.5 hover:text-white transition">
            <Icon name="mail" class="w-4 h-4 text-terra-bright shrink-0" /> {site.email}
          </a>
        </li>
        <li>
          <a href={`tel:${site.phoneIntl}`} class="inline-flex items-center gap-2.5 hover:text-white transition">
            <Icon name="phone" class="w-4 h-4 text-terra-bright shrink-0" /> {site.phone}
          </a>
        </li>
      </ul>
      <a href={L("/contact/")} class="btn btn-terra mt-6 text-sm">{t("cta.contact")}</a>
    </div>

    <div class="md:col-span-3">
      <h3 class="font-display font-semibold text-white text-xs uppercase tracking-[0.18em] mb-4">{t("footer.navigation")}</h3>
      <ul class="space-y-2.5 text-sm">
        {navItems.map((n) => (
          <li><a href={L(n.href)} class="hover:text-white transition">{t(n.key)}</a></li>
        ))}
        <li><a href={L("/equipe/")} class="hover:text-white transition">{t("nav.team")}</a></li>
        <li><a href={L("/faq/")} class="hover:text-white transition">{t("nav.faq")}</a></li>
      </ul>
    </div>

    <div class="md:col-span-3">
      <h3 class="font-display font-semibold text-white text-xs uppercase tracking-[0.18em] mb-4">{t("footer.engage")}</h3>
      <ul class="space-y-2.5 text-sm">
        <li><a href={L("/rejoindre/")} class="hover:text-white transition">{t("footer.become_member")}</a></li>
        <li><a href={L("/rejoindre/")} class="hover:text-white transition">{t("footer.become_volunteer")}</a></li>
        <li><a href={L("/partenaires/")} class="hover:text-white transition">{t("footer.become_partner")}</a></li>
        <li><a href={L("/soutenir/")} class="hover:text-white transition">{t("footer.donate")}</a></li>
      </ul>
    </div>

    <div class="md:col-span-2">
      <h3 class="font-display font-semibold text-white text-xs uppercase tracking-[0.18em] mb-4">{t("footer.presence")}</h3>
      <p class="text-sm text-white/80 mb-2">{t("footer.headoffice")} : {site.hq.city} ({site.hq.postal}), {site.hq.country}</p>
      <ul class="space-y-2.5 text-sm">
        {countries[lang].map((c) => <li>{c}</li>)}
      </ul>
      <div class="flex items-center gap-2.5 mt-5">
        <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="icon-chip w-9 h-9 bg-white/8 border border-white/15 text-white/80 hover:text-white hover:bg-white/15 transition-colors"><Icon name="facebook" class="w-4 h-4" /></a>
        <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="icon-chip w-9 h-9 bg-white/8 border border-white/15 text-white/80 hover:text-white hover:bg-white/15 transition-colors"><Icon name="instagram" class="w-4 h-4" /></a>
        <a href={site.social.tiktok} target="_blank" rel="noopener" aria-label="TikTok" class="icon-chip w-9 h-9 bg-white/8 border border-white/15 text-white/80 hover:text-white hover:bg-white/15 transition-colors"><Icon name="tiktok" class="w-4 h-4" /></a>
        <a href={site.social.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp" class="icon-chip w-9 h-9 bg-white/8 border border-white/15 text-white/80 hover:text-white hover:bg-white/15 transition-colors"><Icon name="whatsapp" class="w-4 h-4" /></a>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-cb py-5 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-white/50">
      <p>© {year} {site.legalName}. {t("footer.rights")}</p>
      <nav class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2" aria-label="Liens légaux">
        <a href={L("/mentions-legales/")} class="hover:text-white transition">{t("footer.legal")}</a>
        <a href={L("/confidentialite/")} class="hover:text-white transition">{t("footer.privacy")}</a>
        <a href={L("/faq/")} class="hover:text-white transition">{t("nav.faq")}</a>
      </nav>
    </div>
    <div class="container-cb pb-5 -mt-1 text-center md:text-right">
      <a href="https://overbrand.net" target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 text-xs text-white/40 hover:text-white transition">
        {t("footer.designedby")} <span class="font-display font-600 text-white/70" style="font-weight:600">OverBrand</span>
      </a>
    </div>
  </div>
</footer>
