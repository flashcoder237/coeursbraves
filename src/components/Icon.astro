const isSolid = name in solid;
const body = isSolid ? solid[name] : (line[name] ?? "");
---
{isSolid ? (
  <svg viewBox="0 0 24 24" fill="currentColor" class={cls} style={style} aria-hidden="true" set:html={body} />
) : (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke}
    stroke-linecap="round" stroke-linejoin="round" class={cls} style={style} aria-hidden="true" set:html={body} />
)}
