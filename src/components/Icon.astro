  linkedin: `<path d="M5 3.5a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM3.2 9h3.6v12H3.2V9Zm5.6 0h3.4v1.6h.05c.48-.9 1.65-1.85 3.4-1.85 3.6 0 4.3 2.4 4.3 5.5V21h-3.6v-5.5c0-1.3 0-3-1.8-3s-2.1 1.4-2.1 2.9V21H8.8V9Z"/>`,
