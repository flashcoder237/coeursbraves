---
import { getStrings, type Locale } from "~/i18n/strings";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);
---

<section class="min-h-[100dvh] pt-32 pb-12 px-4 md:px-8 max-w-[1400px] mx-auto flex flex-col lg:flex-row items-center gap-8 lg:gap-16">
  <div class="w-full lg:w-[55%] flex flex-col justify-center z-10 relative reveal">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-8 text-ink-soft text-sm md:text-base font-medium">
      {t.hero.eyebrow.map((label, i) => (
        <>
          {i > 0 && <span class="text-hairline">•</span>}
          <span class="hover:text-ink transition-colors cursor-default">{label}</span>
        </>
      ))}
    </div>

    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] leading-[0.95] tracking-tightest font-semibold text-ink text-balance mb-10">
      {t.hero.title}
    </h1>

    <p class="text-lg md:text-xl text-ink-soft max-w-xl mb-12 font-light leading-relaxed">
      {t.hero.subtitle}
    </p>

    <a
      href="#ecosystem"
      class="w-fit flex items-center gap-3 bg-paper border-hairline rounded-full pl-6 pr-2 py-2 shadow-soft hover:shadow-nav hover:-translate-y-1 transition-all duration-300"
    >
      <span class="text-sm font-medium">{t.hero.cta}</span>
      <span class="w-8 h-8 rounded-full bg-paper-dark flex items-center justify-center">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-red">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <polyline points="6 13 12 19 18 13"></polyline>
        </svg>
      </span>
    </a>
  </div>

  <div class="w-full lg:w-[45%] h-[60vh] lg:h-[85vh] relative reveal">
    <div class="w-full h-full rounded-[1.5rem] lg:rounded-l-[2rem] lg:rounded-r-none overflow-hidden relative shadow-soft border border-black/5">
      <img
        src="https://images.unsplash.com/photo-1589156280159-27698a70f29e?auto=format&fit=crop&w=1200&q=80"
        alt="Jeune professionnelle dans un espace contemporain et lumineux"
        class="w-full h-full object-cover object-center scale-105 hover:scale-100 transition-transform duration-[1.5s]"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-tr from-paper/10 to-accent-ochre/10 mix-blend-overlay"></div>
    </div>

    <div class="absolute -bottom-6 -left-6 bg-white p-4 rounded-xl border-hairline shadow-nav animate-float hidden md:flex items-center gap-4">
      <div class="w-10 h-10 rounded-full bg-accent-green/10 flex items-center justify-center">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-accent-green">
          <path d="M12 22C8 18 4 14 4 9a8 8 0 0 1 16 0c0 5-4 9-8 13Z"></path>
          <path d="M12 9c-2.5 2-2.5 5 0 7"></path>
        </svg>
      </div>
      <div class="pr-2">
        <p class="font-mono text-[10px] text-ink-soft uppercase tracking-wider mb-0.5">{t.hero.focusLabel}</p>
        <p class="font-medium text-sm">{t.hero.focusValue}</p>
      </div>
    </div>
  </div>
</section>
