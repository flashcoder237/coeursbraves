---
import type { PoleView } from "~/lib/poles";
import { poleUrl } from "~/lib/urls";
import type { Locale } from "~/i18n/strings";

interface Props {
  pole: PoleView;
  variant?: "tall" | "wide";
  discoverLabel: string;
  locale: Locale;
}

const { pole, variant = "tall", discoverLabel, locale } = Astro.props;
const href = poleUrl(pole.slug, locale);

const dotClass =
  pole.accent === "green" ? "dot-green" : pole.accent === "red" ? "dot-red" : "dot-ochre";
const accentText =
  pole.accent === "green"
    ? "text-accent-green"
    : pole.accent === "red"
      ? "text-accent-red"
      : "text-accent-ochre";
---

{variant === "tall" ? (
  <a href={href} class="rounded-[1rem] border-hairline bg-white p-2 shadow-soft hover:shadow-nav transition-all duration-300 group flex flex-col reveal h-full">
    <div class="h-48 md:h-64 rounded-[0.75rem] overflow-hidden mb-4 relative">
      <img
        src={pole.image.src}
        alt={pole.image.alt}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[1s]"
        loading="lazy"
      />
    </div>
    <div class="px-3 pb-4 flex flex-col flex-grow">
      <div class="font-mono text-xs text-ink-soft mb-2 flex items-center gap-2">
        <span>{pole.index}</span>
        <span class={`dot ${dotClass}`}></span>
        <span>{pole.nom}</span>
      </div>
      <h3 class="text-xl font-medium tracking-tight mb-1 text-balance">{pole.descriptionCourte}</h3>
      <div class="mt-auto pt-4 flex justify-between items-center text-sm font-medium">
        <span class="hover-underline-anim">{discoverLabel}</span>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class={`${accentText} group-hover:-translate-y-1 group-hover:translate-x-1 transition-transform`}>
          <line x1="7" y1="17" x2="17" y2="7"></line>
          <polyline points="9 7 17 7 17 15"></polyline>
        </svg>
      </div>
    </div>
  </a>
) : (
  <a href={href} class="rounded-[1rem] border-hairline bg-white p-2 shadow-soft hover:shadow-nav transition-all duration-300 group flex flex-col md:flex-row gap-4 reveal">
    <div class="px-4 py-6 md:p-8 flex flex-col flex-grow justify-between w-full md:w-1/2">
      <div>
        <div class="font-mono text-xs text-ink-soft mb-4 flex items-center gap-2">
          <span>{pole.index}</span>
          <span class={`dot ${dotClass}`}></span>
          <span>{pole.nom}</span>
        </div>
        <h3 class="text-2xl md:text-3xl font-medium leading-tight mb-3 text-balance">{pole.descriptionCourte}</h3>
        <ul class="flex flex-wrap gap-2 mt-4">
          {pole.services.map((s) => (
            <li class="font-mono text-[10px] uppercase tracking-wider border-hairline rounded-full px-2 py-1 text-ink-soft bg-paper">{s}</li>
          ))}
        </ul>
      </div>
      <div class="mt-8 flex justify-between items-center text-sm font-medium">
        <span class="hover-underline-anim">{discoverLabel}</span>
        <span class={`w-8 h-8 rounded-full border-hairline flex items-center justify-center group-hover:bg-ink group-hover:text-white group-hover:border-ink transition-colors`}>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="13 6 19 12 13 18"></polyline>
          </svg>
        </span>
      </div>
    </div>
    <div class="h-48 md:h-auto w-full md:w-1/2 rounded-[0.75rem] overflow-hidden order-first md:order-last">
      <img
        src={pole.image.src}
        alt={pole.image.alt}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[1s]"
        loading="lazy"
      />
    </div>
  </a>
)}
