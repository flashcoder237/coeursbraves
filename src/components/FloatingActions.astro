---
import Icon from "./Icon.astro";
import { site } from "~/data/site";
---
<div class="fab-stack" aria-label="Actions rapides">
  <a href={site.social.whatsapp} target="_blank" rel="noopener"
     class="fab fab-wa" aria-label="Nous écrire sur WhatsApp" title="WhatsApp">
    <Icon name="whatsapp" class="w-6 h-6" />
  </a>
  <a href="/soutenir/" class="fab fab-don" aria-label="Faire un don">
    <Icon name="hand-heart" class="w-5 h-5" />
    <span class="fab-don-label">Faire un don</span>
  </a>
  <button type="button" id="cb-top" class="fab fab-top" aria-label="Revenir en haut de la page">
    <Icon name="arrow-up-right" class="w-5 h-5" style="transform:rotate(-45deg)" />
  </button>
</div>

<script is:inline>
  (function () {
    var btn = document.getElementById("cb-top");
    if (!btn) return;
    var onScroll = function () {
      if (window.scrollY > 600) btn.classList.add("is-visible");
      else btn.classList.remove("is-visible");
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    btn.addEventListener("click", function () {
      var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      window.scrollTo({ top: 0, behavior: reduce ? "auto" : "smooth" });
    });
  })();
</script>
