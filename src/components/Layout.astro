---
import "~/styles/global.css";
import Nav from "./Nav.astro";
import Footer from "./Footer.astro";
import CookieBanner from "./CookieBanner.astro";
import FloatingActions from "./FloatingActions.astro";
import Search from "./Search.astro";
import { site } from "~/data/site";
import { languages, getLangFromUrl, switchLangPath, type Lang } from "~/i18n/ui";

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  ogType?: string;
}
const {
  title, description,
  image = "/images/cb/hero-community.jpg",
  imageAlt, imageWidth, imageHeight, ogType = "website",
} = Astro.props;
const fullTitle = title === site.name ? `${site.name} — Investir dans l'humain` : `${title} — ${site.name}`;
const desc = description ?? "Association internationale africaine qui investit dans l'humain pour créer des opportunités durables.";
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
const ogImage = new URL(image, Astro.site ?? Astro.url.origin).href;
// Dimensions : uniquement si connues (défaut = image d'accueil 1672×941), sinon on omet
const isDefaultImg = image === "/images/cb/hero-community.jpg";
const ogW = imageWidth ?? (isDefaultImg ? 1672 : undefined);
const ogH = imageHeight ?? (isDefaultImg ? 941 : undefined);
const ogAlt = imageAlt ?? "La communauté Cœurs Braves réunie";
const ogImageType = image.toLowerCase().endsWith(".png") ? "image/png" : "image/jpeg";
const lang = getLangFromUrl(Astro.url);
const base = Astro.site ?? new URL(Astro.url.origin);
const alternates = (Object.keys(languages) as Lang[]).map((code) => ({
  code,
  href: new URL(switchLangPath(Astro.url, code), base).href,
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.code} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph / réseaux sociaux -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={lang === "en" ? "en_US" : lang === "de" ? "de_DE" : "fr_FR"} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content={ogImageType} />
    {ogW && <meta property="og:image:width" content={String(ogW)} />}
    {ogH && <meta property="og:image:height" content={String(ogH)} />}
    <meta property="og:image:alt" content={ogAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogAlt} />
  </head>
  <body class="min-h-screen bg-paper text-ink antialiased" data-contact-email={site.email}>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <Search />
    <FloatingActions />
    <CookieBanner />

    <script is:inline>
      // Mémorise la langue de la page courante (cookie lu par le middleware Vercel) :
      // ainsi un choix manuel via le sélecteur prime sur la détection automatique.
      (function () {
        var seg = location.pathname.split("/")[1];
        var lang = seg === "en" || seg === "de" ? seg : "fr";
        document.cookie = "cb-lang=" + lang + "; path=/; max-age=31536000; samesite=lax";
      })();
    </script>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const els = document.querySelectorAll(".reveal");
        if (!els.length) return;
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                obs.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      });
    </script>

    <script is:inline>
      // Compteur animé des chiffres d'impact (au scroll, une seule fois).
      document.addEventListener("DOMContentLoaded", () => {
        const nums = document.querySelectorAll(".stat-num");
        if (!nums.length) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        const fmt = new Intl.NumberFormat("fr-FR");
        const animate = (el) => {
          const original = el.textContent.trim();
          const target = parseInt(original.replace(/[^\d]/g, ""), 10);
          if (!target) return;
          const suffix = original.replace(/[\d\s  ]/g, "");
          const dur = 1500, start = performance.now();
          el.textContent = fmt.format(0) + suffix;
          const step = (now) => {
            const p = Math.min((now - start) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            if (p < 1) {
              el.textContent = fmt.format(Math.round(target * eased)) + suffix;
              requestAnimationFrame(step);
            } else {
              el.textContent = original; // restaure le formatage exact
            }
          };
          requestAnimationFrame(step);
        };
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (e.isIntersecting) { animate(e.target); obs.unobserve(e.target); }
            }
          },
          { threshold: 0.5 }
        );
        nums.forEach((n) => io.observe(n));
      });
    </script>

    <script is:inline>
      // Formulaires fonctionnels sans backend : construction d'un e-mail pré-rempli.
      document.addEventListener("DOMContentLoaded", () => {
        const forms = document.querySelectorAll("form.cb-form");
        if (!forms.length) return;
        const email = document.body.dataset.contactEmail || "contact@coeursbraves.com";
        forms.forEach((form) => {
          form.addEventListener("submit", (ev) => {
            ev.preventDefault();
            if (typeof form.reportValidity === "function" && !form.reportValidity()) return;
            const lines = [];
            form.querySelectorAll("input, select, textarea").forEach((el) => {
              if (el.type === "submit" || el.type === "button") return;
              const val = (el.value || "").trim();
              if (!val) return;
              let label = el.getAttribute("placeholder") || el.getAttribute("name") || "";
              if (el.tagName === "SELECT") {
                const first = el.options[0] ? el.options[0].text.trim() : "";
                if (val === first) return; // aucun choix
                label = el.dataset.label || first || "Choix";
              }
              lines.push(label + " : " + val);
            });
            const subject = form.dataset.subject || "Message depuis le site";
            const href =
              "mailto:" + email +
              "?subject=" + encodeURIComponent(subject) +
              "&body=" + encodeURIComponent(lines.join("\n"));
            // Confirmation affichée d'abord (garantie même si le client mail s'ouvre).
            let note = form.nextElementSibling;
            if (!note || !note.classList.contains("cb-form-note")) {
              note = document.createElement("p");
              note.className = "cb-form-note";
              form.insertAdjacentElement("afterend", note);
            }
            note.textContent =
              "Votre logiciel de messagerie va s'ouvrir pour finaliser l'envoi. " +
              "Si rien ne se passe, écrivez-nous directement à " + email + ".";
            // Ouverture du client mail via une ancre temporaire (ne recharge pas la page).
            const a = document.createElement("a");
            a.href = href;
            a.style.display = "none";
            document.body.appendChild(a);
            a.click();
            a.remove();
          });
        });
      });
    </script>
  </body>
</html>
