---
import { getStrings, type Locale } from "~/i18n/strings";
import { loadPartners } from "~/lib/orgs";
import { partnerUrl } from "~/lib/urls";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);
const partners = await loadPartners(locale);

const typeLabels: Record<string, Record<Locale, string>> = {
  institutionnel: { fr: "Institutionnel", en: "Institutional", de: "Institutionell" },
  financier: { fr: "Financier", en: "Financial", de: "Finanziell" },
  media: { fr: "Médias", en: "Media", de: "Medien" },
  technologique: { fr: "Technologique", en: "Technology", de: "Technologie" },
  academique: { fr: "Académique", en: "Academic", de: "Akademisch" },
  ong: { fr: "ONG", en: "NGO", de: "NGO" },
};
---

{partners.length > 0 && (
  <section id="partners" class="py-24 md:py-32 px-4 md:px-8 max-w-[1400px] mx-auto reveal">
    <div class="flex items-end justify-between mb-16 flex-wrap gap-4">
      <div class="max-w-2xl">
        <p class="font-mono text-[11px] uppercase tracking-widest text-ink-soft mb-4">{t.partners.sectionLabel}</p>
        <h2 class="text-3xl md:text-5xl font-semibold tracking-tight text-balance mb-4">{t.partners.title}</h2>
        <p class="text-ink-soft text-base md:text-lg font-light leading-relaxed">{t.partners.intro}</p>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      {partners.map((p) => {
        const typeLabel = typeLabels[p.data.type]?.[locale] ?? p.data.type;
        return (
          <a href={partnerUrl(p.data.slug, locale)} class="group block h-full">
            <div class="h-full rounded-[1rem] border-hairline bg-white p-6 md:p-7 flex flex-col shadow-soft hover:shadow-nav hover:-translate-y-1 transition-all duration-300">
              <span class="font-mono text-[10px] uppercase tracking-widest text-ink-soft mb-4">{typeLabel}</span>
              {p.data.logo ? (
                <div class="h-14 mb-4 flex items-center">
                  <img src={p.data.logo} alt={p.data.nom} class="max-h-full max-w-[80%] object-contain grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all" loading="lazy" />
                </div>
              ) : (
                <h3 class="text-lg md:text-xl font-semibold tracking-tight mb-3 text-ink leading-tight">{p.data.nom}</h3>
              )}
              {p.data.descriptionCourte && (
                <p class="text-sm text-ink-soft leading-relaxed flex-grow">{p.data.descriptionCourte}</p>
              )}
              <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium font-mono uppercase tracking-widest text-ink-soft group-hover:text-ink transition-colors">
                <span>{t.partners.visitLink}</span>
                <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="13 6 19 12 13 18"></polyline>
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}
